<UserControl x:Class="BlackbirdInterface.PerformancePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BlackbirdInterface"
             Background="{DynamicResource WinPanelBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Background="{DynamicResource PerformanceHeaderBrush}"
              MouseLeftButtonDown="Header_MouseLeftButtonDown"
              MouseMove="Header_MouseMove"
              MouseLeftButtonUp="Header_MouseLeftButtonUp">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource PerformanceHeaderAccentBrush}"/>

            <TextBlock Grid.Column="1"
                       Text="Performance"
                       Margin="8,0,10,0"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="PerfSubTitle"
                       Grid.Column="2"
                       HorizontalAlignment="Left"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource WinMutedTextBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <Button Grid.Column="3"
                    x:Name="PerfBtnReorder"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⇅"
                    Width="22"
                    Height="22"
                    ToolTip="Reorder panes"
                    Click="PerfBtnReorder_Click"/>
            <Button Grid.Column="4"
                    x:Name="PerfBtnFloat"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⧉"
                    Width="22"
                    Height="22"
                    Click="PerfBtnFloat_Click"/>
            <Button Grid.Column="5"
                    x:Name="PerfBtnClose"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="✕"
                    Width="22"
                    Height="22"
                    Margin="4,4,6,4"
                    Click="PerfBtnClose_Click"/>
        </Grid>

        <Grid Grid.Row="1" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*" MinHeight="190"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*" MinHeight="150"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                    BorderThickness="1"
                    Padding="8,5"
                    Margin="0,0,0,2"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ToggleButton x:Name="TimeTravelToggle"
                                  Content="Time Travel"
                                  Padding="8,2"
                                  VerticalAlignment="Center"
                                  Checked="TimeTravelToggle_Checked"
                                  Unchecked="TimeTravelToggle_Unchecked"/>

                    <Slider x:Name="TimeTravelSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="0"
                            Value="0"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            IsEnabled="False"
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            ValueChanged="TimeTravelSlider_ValueChanged"/>

                    <TextBlock x:Name="TimeTravelStampBlock"
                               Grid.Column="2"
                               Text="LIVE"
                               Foreground="{DynamicResource WinMutedTextBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ClipToBounds="True" Margin="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,6,0"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        Background="{DynamicResource WinPanelBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="72"/>
                        </Grid.RowDefinitions>
                        <local:PerformanceChartControl x:Name="CpuChart" Grid.Row="0" Title="CPU"/>
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Core Heat"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource WinMutedTextBrush}"/>
                                <ItemsControl x:Name="CoreHeatGrid"
                                              Grid.Row="1"
                                              ItemsSource="{Binding CoreUsageRows, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="22"
                                                    Height="18"
                                                    Margin="1"
                                                    Background="{Binding Fill}"
                                                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                    BorderThickness="1"
                                                    ToolTip="{Binding ToolTip}">
                                                <TextBlock Text="{Binding CoreLabel}"
                                                           FontSize="9"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource WinTextBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <local:PerformanceChartControl x:Name="DiskChart" Grid.Column="1" Title="Disk IO" Margin="0,0,6,0"/>
                <local:PerformanceChartControl x:Name="RamChart" Grid.Column="2" Title="RAM" Margin="0,0,6,0"/>
                <Border Grid.Column="3"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        Background="{DynamicResource WinPanelBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource WinHeaderBrush}"
                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,0">
                            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                <TextBlock x:Name="NetworkPaneTitle"
                                           Text="Network Traffic"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="NetworkViewSwitchButton"
                                        DockPanel.Dock="Right"
                                        Content="Peers"
                                        Visibility="Collapsed"
                                        MinWidth="54"
                                        MinHeight="0"
                                        Height="18"
                                        Padding="6,0"
                                        Margin="6,0,0,0"
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        ToolTip="Toggle traffic/peers view"
                                        Click="NetworkViewSwitchButton_Click"/>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <local:PerformanceChartControl x:Name="NetChart"
                                                           Title="Network"
                                                           Visibility="Visible"/>
                            <DataGrid x:Name="NetworkPeersGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      GridLinesVisibility="None"
                                      HorizontalGridLinesBrush="Transparent"
                                      VerticalGridLinesBrush="Transparent"
                                      CanUserResizeRows="False"
                                      ColumnHeaderHeight="24"
                                      RowHeight="22"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Remote Socket" Width="170" Binding="{Binding RemoteEndpoint}"/>
                                    <DataGridTextColumn Header="DNS" Width="200" Binding="{Binding DnsName}"/>
                                    <DataGridTextColumn Header="Proto" Width="60" Binding="{Binding Protocol}"/>
                                    <DataGridTextColumn Header="State" Width="100" Binding="{Binding State}"/>
                                    <DataGridTextColumn Header="Hits" Width="50" Binding="{Binding ConnectionCount}"/>
                                    <DataGridTextColumn Header="Sent (B)" Width="80" Binding="{Binding BytesSent}"/>
                                    <DataGridTextColumn Header="Recv (B)" Width="80" Binding="{Binding BytesRecv}"/>
                                    <DataGridTextColumn Header="First Seen" Width="140" Binding="{Binding FirstSeen, StringFormat=\{0:HH:mm:ss.fff\}}"/>
                                    <DataGridTextColumn Header="Last Seen" Width="140" Binding="{Binding LastSeen, StringFormat=\{0:HH:mm:ss.fff\}}"/>
                                    <DataGridTextColumn Header="Src" Width="60" Binding="{Binding Source}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="NetworkNoDataOverlay"
                                    Background="{DynamicResource NoDataOverlayBrush}"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="NO DATA"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Opacity="0.72"
                                               Foreground="{DynamicResource WinTextBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="2"
                          Height="2"
                          Background="{DynamicResource WinSubtleBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource WinPanelBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        Padding="0"
                        ClipToBounds="True"
                        Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource WinHeaderBrush}"
                                BorderBrush="{DynamicResource WinBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,0">
                            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                <TextBlock Text="Threads" FontWeight="SemiBold"/>
                                <Button x:Name="ParallelStacksButton"
                                        DockPanel.Dock="Right"
                                        Margin="8,0,0,0"
                                        MinWidth="88"
                                        Height="18"
                                        Padding="6,1"
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        Click="ParallelStacksButton_Click"
                                        Content="Parallel Stacks"/>
                                <ToggleButton x:Name="ThreadLifecycleToggle"
                                              DockPanel.Dock="Right"
                                              Margin="8,0,0,0"
                                              MinWidth="64"
                                              Height="18"
                                              Padding="6,1"
                                              FontSize="10"
                                              VerticalAlignment="Center"
                                              Checked="ThreadLifecycleToggle_Checked"
                                              Unchecked="ThreadLifecycleToggle_Unchecked"
                                              Content="Lifecycle"
                                              Visibility="Collapsed"/>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="ThreadsGrid"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      Margin="0"
                                      ColumnHeaderHeight="24"
                                      RowHeight="22"
                                      CanUserResizeRows="False"
                                      PreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                      MouseDoubleClick="ThreadsGrid_MouseDoubleClick">
                                <DataGrid.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Open Thread Stack" Click="ThreadContextOpenStack_Click"/>
                                        <MenuItem Header="Open Parallel Stacks" Click="ThreadContextParallelStacks_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Copy Thread ID" Click="ThreadContextCopyTid_Click"/>
                                    </ContextMenu>
                                </DataGrid.ContextMenu>
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuspended}" Value="True">
                                                <Setter Property="Foreground" Value="#FFF8E9AF"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                <Setter Property="Foreground" Value="#FFBEBEBE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="TID" Binding="{Binding Tid}" Width="72"/>
                                    <DataGridTextColumn Header="CPU ms" Binding="{Binding CpuMs}" Width="90"/>
                                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="160"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ThreadKind}" Width="150"/>
                                    <DataGridTextColumn Header="Start" Binding="{Binding StartTime}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="ThreadLifecycleGrid"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      Margin="0"
                                      ColumnHeaderHeight="24"
                                      RowHeight="22"
                                      Visibility="Collapsed"
                                      CanUserResizeRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="86"/>
                                    <DataGridTextColumn Header="Event" Binding="{Binding EventKind}" Width="76"/>
                                    <DataGridTextColumn Header="TID" Binding="{Binding Tid}" Width="72"/>
                                    <DataGridTextColumn Header="Creator" Binding="{Binding CreatorPid}" Width="82"/>
                                    <DataGridTextColumn Header="Flags" Binding="{Binding Flags}" Width="86"/>
                                    <DataGridTextColumn Header="Start" Binding="{Binding StartAddress}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="ThreadsNoDataOverlay"
                                    Background="{DynamicResource NoDataOverlayBrush}"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="NO DATA"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Opacity="0.72"
                                               Foreground="{DynamicResource WinTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ThreadsNoDataMessageBlock"
                                               Margin="0,6,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource WinMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Text="No thread data in the selected range."/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <Border Grid.Column="2"
                        Background="{DynamicResource WinPanelBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        Padding="0">
                    <Grid x:Name="ProcessDetailsLayout" SizeChanged="ProcessDetailsLayout_SizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ModulesColumn" Width="3*"/>
                            <ColumnDefinition x:Name="DetailsSplitterColumn" Width="2"/>
                            <ColumnDefinition x:Name="MemoryColumn" Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="0"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="ModulesPanel"
                                Grid.Row="0"
                                Grid.Column="0"
                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                BorderThickness="0,0,1,0"
                                Padding="0">
                            <TabControl Padding="0">
                                <TabItem Header="Modules">
                                    <DataGrid x:Name="ModulesGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              GridLinesVisibility="None"
                                              HorizontalGridLinesBrush="Transparent"
                                              VerticalGridLinesBrush="Transparent"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              PreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                              MouseDoubleClick="ModulesGrid_MouseDoubleClick">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open PE View" Click="ModuleContextOpenPe_Click"/>
                                                <Separator/>
                                                <MenuItem Header="Copy Path" Click="ModuleContextCopyPath_Click"/>
                                                <MenuItem Header="Copy Base Address" Click="ModuleContextCopyBase_Click"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Module" Binding="{Binding Name}" Width="170"/>
                                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="78"/>
                                            <DataGridTextColumn Header="Base" Binding="{Binding BaseAddress}" Width="130"/>
                                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="85"/>
                                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>

                                <TabItem Header="PE">
                                    <DataGrid x:Name="PeInfoGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              GridLinesVisibility="None"
                                              HorizontalGridLinesBrush="Transparent"
                                              VerticalGridLinesBrush="Transparent"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="220"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                            </TabControl>
                        </Border>

                        <GridSplitter x:Name="DetailsSplitter"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Width="2"
                                      Background="{DynamicResource WinSubtleBorderBrush}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>

                        <Border x:Name="MemoryPanel"
                                Grid.Row="0"
                                Grid.Column="2"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource WinHeaderBrush}"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,0">
                                    <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                        <TextBlock Text="Memory"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="MemoryAttributionToggle"
                                                      Margin="8,0,0,0"
                                                      Padding="8,2"
                                                      VerticalAlignment="Center"
                                                      Checked="MemoryAttributionToggle_Checked"
                                                      Unchecked="MemoryAttributionToggle_Unchecked"
                                                      Content="Inspector Window"/>
                                        <ToggleButton x:Name="MemorySummaryToggle"
                                                      Margin="8,0,0,0"
                                                      Padding="8,2"
                                                      VerticalAlignment="Center"
                                                      Checked="MemorySummaryToggle_Checked"
                                                      Unchecked="MemorySummaryToggle_Unchecked"
                                                      Content="Treemap"/>
                                    </DockPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <DataGrid x:Name="MemoryGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              Visibility="Collapsed">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="220"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DataGrid x:Name="MemoryAttributionGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              GridLinesVisibility="None"
                                              HorizontalGridLinesBrush="Transparent"
                                              VerticalGridLinesBrush="Transparent"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              Visibility="Collapsed"
                                              PreviewMouseRightButtonDown="DataGridRow_PreviewMouseRightButtonDown"
                                              MouseDoubleClick="MemoryAttributionGrid_MouseDoubleClick">
                                        <DataGrid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open Thread Stack" Click="MemoryContextOpenStack_Click"/>
                                                <MenuItem Header="Copy Base Address" Click="MemoryContextCopyBase_Click"/>
                                            </ContextMenu>
                                        </DataGrid.ContextMenu>
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Padding" Value="6,0"/>
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PriorityBand}" Value="PrivateUnsigned">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryPrivateUnsignedBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryPrivateUnsignedForegroundBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityBand}" Value="PrivateExecutable">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryPrivateExecutableBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryPrivateExecutableForegroundBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityBand}" Value="Private">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryPrivateBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryPrivateForegroundBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityBand}" Value="Unsigned">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryUnsignedBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryUnsignedForegroundBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityBand}" Value="Image">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryImageBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryImageForegroundBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PriorityBand}" Value="Mapped">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryMappedBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryMappedForegroundBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HighlightBand}" Value="ThreadStack">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryThreadStackBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryThreadStackForegroundBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HighlightBand}" Value="Heap">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryHeapBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryHeapForegroundBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HighlightBand}" Value="Anchor">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryAnchorBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryAnchorForegroundBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HighlightBand}" Value="Runtime">
                                                        <Setter Property="Background" Value="{DynamicResource MemoryRuntimeBackgroundBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MemoryRuntimeForegroundBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Tag" Binding="{Binding HighlightLabel}" Width="74">
                                                <DataGridTextColumn.CellStyle>
                                                    <Style TargetType="DataGridCell">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WinSubtleBorderBrush}"/>
                                                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                                        <Setter Property="Padding" Value="6,0"/>
                                                    </Style>
                                                </DataGridTextColumn.CellStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Base" Binding="{Binding BaseAddress}" Width="132"/>
                                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="92"/>
                                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="82"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="82"/>
                                            <DataGridTextColumn Header="Protect" Binding="{Binding Protect}" Width="170"/>
                                            <DataGridTextColumn Header="Class" Binding="{Binding Category}" Width="180"/>
                                            <DataGridTextColumn Header="Allocator / Thread" Binding="{Binding Allocator}" Width="230"/>
                                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130"/>
                                            <DataGridTextColumn Header="Context" Binding="{Binding Context}" Width="190"/>
                                            <DataGridTextColumn Header="Lifecycle" Binding="{Binding Lifecycle}" Width="190"/>
                                            <DataGridTextColumn Header="Trust" Binding="{Binding Trust}" Width="86"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Grid x:Name="MemoryTreemapHost"
                                          Visibility="Visible">
                                        <Border BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                BorderThickness="0"
                                                Background="{DynamicResource WinPanelBrush}">
                                            <Canvas x:Name="MemoryTreemapCanvas"/>
                                        </Border>

                                        <TextBlock x:Name="MemoryTreemapNoData"
                                                   Text="NO DATA"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource WinMutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Grid>

                                    <Border x:Name="MemoryNoDataOverlay"
                                            Background="{DynamicResource NoDataOverlayBrush}"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="NO DATA"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Opacity="0.72"
                                                       Foreground="{DynamicResource WinTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="MemoryNoDataMessageBlock"
                                                       Margin="0,6,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource WinMutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       Text="No memory data in the selected range."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>



