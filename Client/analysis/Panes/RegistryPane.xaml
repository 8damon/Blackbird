<UserControl x:Class="BlackbirdInterface.RegistryPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WinPanelBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource RegistryHeaderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="10,0,8,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Text="Registry"/>

            <ComboBox x:Name="CategoryFilter"
                      Grid.Column="1"
                      Width="100"
                      Height="24"
                      Margin="4,4,4,4"
                      VerticalAlignment="Center"
                      IsEditable="False"
                      VerticalContentAlignment="Center"
                      Style="{StaticResource PaneFilterComboStyle}"
                      ItemContainerStyle="{StaticResource PaneFilterComboItemStyle}"
                      SelectionChanged="CategoryFilter_SelectionChanged"/>

            <ComboBox x:Name="SeverityFilter"
                      Grid.Column="2"
                      Width="100"
                      Height="24"
                      Margin="0,4,6,4"
                      VerticalAlignment="Center"
                      IsEditable="False"
                      VerticalContentAlignment="Center"
                      Style="{StaticResource PaneFilterComboStyle}"
                      ItemContainerStyle="{StaticResource PaneFilterComboItemStyle}"
                      SelectionChanged="SeverityFilter_SelectionChanged"/>

            <TextBox x:Name="SearchBox"
                     Grid.Column="3"
                     Height="24"
                     Margin="0,4,4,4"
                     VerticalContentAlignment="Center"
                     VerticalAlignment="Center"
                     ToolTip="Filter by key path, value, operation, actor, or classification"
                     TextChanged="SearchBox_TextChanged"/>

            <Button Grid.Column="4"
                    x:Name="RegistryBtnInspect"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="↗"
                    Width="22"
                    Height="22"
                    ToolTip="Open registry inspector"
                    Click="RegistryBtnInspect_Click"/>

            <Button Grid.Column="5"
                    x:Name="RegistryBtnClose"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="✕"
                    Width="22"
                    Height="22"
                    Margin="4,4,6,4"
                    ToolTip="Hide pane"
                    Click="RegistryBtnClose_Click"/>
        </Grid>

        <Border Grid.Row="1"
                Margin="0"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="0">
            <Grid>
                <DataGrid x:Name="RegistryGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          HorizontalGridLinesBrush="Transparent"
                          VerticalGridLinesBrush="Transparent"
                          CanUserResizeRows="False"
                          ColumnHeaderHeight="24"
                          RowHeight="22"
                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseRightButtonDown="RegistryGrid_PreviewMouseRightButtonDown"
                          MouseDoubleClick="RegistryGrid_MouseDoubleClick">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Inspect Registry Activity" Click="RegistryContextInspect_Click"/>
                            <Separator/>
                            <MenuItem Header="Copy Summary" Click="RegistryContextCopySummary_Click"/>
                            <MenuItem Header="Copy Details" Click="RegistryContextCopyDetails_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource AppDataGridRowStyle}">
                            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                    <Setter Property="Background" Value="#295E1E1E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                    <Setter Property="Background" Value="#255A1D1D"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                    <Setter Property="Background" Value="#1F5C3A1A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Low">
                                    <Setter Property="Background" Value="#1C4C4217"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E303030"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#33323232"/>
                                    <Setter Property="Foreground" Value="#FFF1F1F1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource AppDataGridCellStyle}">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Operation"       Width="160" Binding="{Binding Event}"/>
                        <DataGridTextColumn Header="Severity"        Width="90"  Binding="{Binding Severity}"/>
                        <DataGridTextColumn Header="Hits"            Width="52"  Binding="{Binding Hits}"/>
                        <DataGridTextColumn Header="Key Path"        Width="*"   Binding="{Binding Detection}"/>
                        <DataGridTextColumn Header="Value / Tag"     Width="200" Binding="{Binding ArgumentPreview}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="NoDataOverlay"
                        Background="{DynamicResource NoDataOverlayBrush}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <TextBlock Text="NO DATA"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WinTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.72"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
