                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DetailLabel}"
                                                                   Margin="8,0"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1"
                              x:Name="IntelligenceSplitter"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <Grid Grid.Column="2" x:Name="IntelligenceDock">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            x:Name="EtwDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,1,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:EtwPane x:Name="EtwPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="2"
                            x:Name="HeuristicsDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:HeuristicsPane x:Name="HeuristicsPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="3"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="4"
                            x:Name="FilesystemDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:FilesystemPane x:Name="FilesystemPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="5"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="6"
                            x:Name="RegistryDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:RegistryPane x:Name="RegistryPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="7"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="8"
                            x:Name="ProcessRelationsDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,1"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:ProcessRelationsPane x:Name="ProcessRelationsPaneHost"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border x:Name="SwitchToastBorder"
                Grid.Row="0"
                Grid.RowSpan="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="28,14"
                CornerRadius="4"
                Background="#CC101010"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="1"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed">
            <TextBlock x:Name="SwitchToastText"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource WinTextBrush}"
                       TextAlignment="Center"/>
        </Border>

    </Grid>
</Window>


