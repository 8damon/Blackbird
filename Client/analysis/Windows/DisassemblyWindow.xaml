<Window x:Class="BlackbirdInterface.DisassemblyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BlackbirdInterface"
        Title="Disassembly"
        Height="720"
        Width="1200"
        MinHeight="420"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">

    <Window.Resources>
        <Style x:Key="InsnRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RowKind}" Value="Ret">
                    <Setter Property="Foreground" Value="#888888"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowKind}" Value="Dead">
                    <Setter Property="Foreground" Value="#404040"/>
                    <Setter Property="FontStyle" Value="Italic"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowKind}" Value="ByteMatch">
                    <Setter Property="Background" Value="#2A2A1A"/>
                    <Setter Property="BorderBrush" Value="#AAAA00"/>
                    <Setter Property="BorderThickness" Value="0,1,0,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowKind}" Value="CrossRef">
                    <Setter Property="Background" Value="#221808"/>
                    <Setter Property="BorderBrush" Value="#FF8800"/>
                    <Setter Property="BorderThickness" Value="0,1,0,1"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowKind}" Value="DirectSyscall">
                    <Setter Property="Background" Value="#2A0A0A"/>
                    <Setter Property="BorderBrush" Value="#FF4040"/>
                    <Setter Property="BorderThickness" Value="0,1,0,1"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InsnCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="A" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.SelectAll}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource WinHeaderBrush}"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="TitleBlock"
                           DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource WinTextBrush}"/>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                        Content="&#xE8BB;"
                        Tag="Close"
                        ToolTip="Close"
                        Click="CloseButton_Click"/>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                        Content="&#xE8C8;"
                        Tag="Copy"
                        ToolTip="Copy selected instructions to clipboard (Ctrl+C)"
                        Click="CopySelected_Click"/>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                        Content="&#xE74C;"
                        Tag="ClearHighlights"
                        ToolTip="Clear scan highlights"
                        Click="ClearHighlights_Click"/>
            </DockPanel>
        </Border>

        <!-- Instruction grid -->
        <DataGrid x:Name="InsnGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  BorderThickness="0"
                  GridLinesVisibility="None"
                  HorizontalGridLinesBrush="Transparent"
                  VerticalGridLinesBrush="Transparent"
                  CanUserResizeRows="False"
                  ColumnHeaderHeight="24"
                  RowHeight="22"
                  HeadersVisibility="Column"
                  EnableRowVirtualization="True"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  RowStyle="{StaticResource InsnRowStyle}"
                  CellStyle="{StaticResource InsnCellStyle}"
                  Background="{DynamicResource WinPanelBrush}"
                  Foreground="{DynamicResource WinTextBrush}"
                  BorderBrush="{DynamicResource WinBorderBrush}"
                  FontFamily="{DynamicResource AppMonoFontFamily}"
                  FontSize="12"
                  KeyDown="InsnGrid_KeyDown"
                  PreviewKeyDown="InsnGrid_PreviewKeyDown">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy Selected" InputGestureText="Ctrl+C"  Click="CopySelected_Click"/>
                    <MenuItem Header="Copy All"      InputGestureText="Ctrl+Shift+C" Click="CopyAll_Click"/>
                    <Separator/>
                    <MenuItem Header="Find Byte Pattern..."   Click="ScanBytePattern_Click"
                              ToolTip="Highlight instructions whose raw bytes match a hex pattern (wildcards: ??)"/>
                    <MenuItem Header="Find Calls/Jumps To..." Click="ScanCallsTo_Click"
                              ToolTip="Highlight all CALL/JMP instructions targeting a given address or symbol"/>
                    <MenuItem Header="Scan YARA Hex String..." Click="ScanYaraHex_Click"
                              ToolTip="Highlight matches for a YARA-style hex string  e.g.  { 48 8B ?? 04 25 }"/>
                    <Separator/>
                    <MenuItem Header="Clear Highlights" Click="ClearHighlights_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <!-- Address: label+RVA -->
                <DataGridTextColumn Header="Address"
                                    Binding="{Binding AddressText}"
                                    Width="200"/>

                <!-- Bytes: raw hex -->
                <DataGridTextColumn Header="Bytes"
                                    Binding="{Binding BytesText}"
                                    Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#606060"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Mnemonic: colored by instruction class -->
                <DataGridTemplateColumn Header="Mnemonic" Width="84">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Mnemonic}"
                                       Foreground="{Binding MnemonicBrush}"
                                       Padding="6,0,6,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Operands: token-level syntax coloring via attached Inlines -->
                <DataGridTemplateColumn Header="Operands" Width="280">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock local:InlinesHelper.InlinesSource="{Binding OperandsInlines}"
                                       Padding="6,0,6,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Resolved: call/jump target with coloring -->
                <DataGridTemplateColumn Header="Resolved" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock local:InlinesHelper.InlinesSource="{Binding ResolvedInlines}"
                                       Padding="6,0,6,0"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource WinHeaderBrush}"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBlock"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource WinMutedTextBrush}"/>
        </Border>
    </Grid>
</Window>
