<Window x:Class="BlackbirdInterface.OperatorCaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Operator Case"
        Height="920"
        Width="1580"
        MinHeight="760"
        MinWidth="1260"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="CaseHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style x:Key="CaseMutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WinMutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="CaseSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style x:Key="CaseReadOnlyTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Background" Value="#FF111111"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="BorderBrush" Value="#FF303030"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="CaseActionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#FF172033"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="BorderBrush" Value="#FF36506D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="CaseDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Background" Value="#FF111111"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="BorderBrush" Value="#FF242424"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                    <Setter Property="Background" Value="#FF2A1216"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="High">
                    <Setter Property="Background" Value="#FF2B1D10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                    <Setter Property="Background" Value="#FF111F2D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="Low">
                    <Setter Property="Background" Value="#FF10221A"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF233A52"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SecondaryWindowTitleBarBorderStyle}"
                MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Operator Case"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Subtitle}"
                               Margin="0,3,0,0"
                               Style="{StaticResource SecondaryWindowSubtitleTextStyle}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="Copy Report"
                            Style="{StaticResource CaseActionButtonStyle}"
                            Click="CopyReport_Click"/>
                    <Button Content="Copy IOCs"
                            Style="{StaticResource CaseActionButtonStyle}"
                            Click="CopyIocs_Click"/>
                    <Button Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                            Content="&#xE921;"
                            Click="WindowMinimize_Click"/>
                    <Button Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                            Content="&#xE922;"
                            Click="WindowMaximize_Click"/>
                    <Button Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                            Tag="Close"
                            Content="&#xE8BB;"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="6" Margin="0,0,0,10">
                <Border Margin="0,0,8,0" Padding="10,8" Background="#FF211318" BorderBrush="#FFB64A55" BorderThickness="3,1,1,1">
                    <StackPanel>
                        <TextBlock Text="Risk" Style="{StaticResource CaseMutedTextStyle}"/>
                        <TextBlock Text="{Binding RiskLabel}" Style="{StaticResource CaseHeaderStyle}"/>
                        <TextBlock Text="{Binding RiskScore, StringFormat={}{0}/100}" Style="{StaticResource CaseMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,8,0" Padding="10,8" Background="#FF172033" BorderBrush="#FF4B7DB8" BorderThickness="3,1,1,1">
                    <StackPanel>
                        <TextBlock Text="Detections" Style="{StaticResource CaseMutedTextStyle}"/>
                        <TextBlock Text="{Binding DetectionCount}" Style="{StaticResource CaseHeaderStyle}"/>
                        <TextBlock Text="operator signals" Style="{StaticResource CaseMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,8,0" Padding="10,8" Background="#FF12221A" BorderBrush="#FF4EAA77" BorderThickness="3,1,1,1">
                    <StackPanel>
                        <TextBlock Text="Evidence" Style="{StaticResource CaseMutedTextStyle}"/>
                        <TextBlock Text="{Binding EvidenceCount}" Style="{StaticResource CaseHeaderStyle}"/>
                        <TextBlock Text="packets" Style="{StaticResource CaseMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,8,0" Padding="10,8" Background="#FF241A12" BorderBrush="#FFBF7A3E" BorderThickness="3,1,1,1">
                    <StackPanel>
                        <TextBlock Text="Chains" Style="{StaticResource CaseMutedTextStyle}"/>
                        <TextBlock Text="{Binding BehaviorChains.Count}" Style="{StaticResource CaseHeaderStyle}"/>
                        <TextBlock Text="clusters" Style="{StaticResource CaseMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,8,0" Padding="10,8" Background="#FF171A25" BorderBrush="#FF8A79C7" BorderThickness="3,1,1,1">
                    <StackPanel>
                        <TextBlock Text="IOCs" Style="{StaticResource CaseMutedTextStyle}"/>
                        <TextBlock Text="{Binding IocCount}" Style="{StaticResource CaseHeaderStyle}"/>
                        <TextBlock Text="deduplicated" Style="{StaticResource CaseMutedTextStyle}"/>
                    </StackPanel>
                </Border>
                <Border Padding="10,8" Background="#FF1F1A12" BorderBrush="#FFC3A35D" BorderThickness="3,1,1,1">
                    <StackPanel>
                        <TextBlock Text="Health" Style="{StaticResource CaseMutedTextStyle}"/>
                        <TextBlock Text="{Binding HealthIssueCount}" Style="{StaticResource CaseHeaderStyle}"/>
                        <TextBlock Text="issues/warnings" Style="{StaticResource CaseMutedTextStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TabControl Grid.Row="1">
                <TabItem Header="Overview">
                    <Grid Margin="8" Background="#FF101418">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="4,4,4,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.05*"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="2.3*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Verdict" Style="{StaticResource CaseSectionHeaderStyle}"/>
                                <TextBlock Text="{Binding Verdict}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{DynamicResource WinTextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Case Summary" Style="{StaticResource CaseSectionHeaderStyle}"/>
                                <TextBlock Text="{Binding Summary}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Foreground="{DynamicResource WinTextBrush}"/>
                            </StackPanel>
                        </Grid>
                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding BehaviorChains}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  RowStyle="{StaticResource CaseDataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="88"/>
                                <DataGridTextColumn Header="Chain" Binding="{Binding Name}" Width="230"/>
                                <DataGridTextColumn Header="Actor" Binding="{Binding Actor}" Width="155"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="155"/>
                                <DataGridTextColumn Header="Tactic" Binding="{Binding Tactic}" Width="150"/>
                                <DataGridTextColumn Header="ATT&amp;CK" Binding="{Binding TechniqueId}" Width="100"/>
                                <DataGridTextColumn Header="Technique" Binding="{Binding Technique}" Width="210"/>
                                <DataGridTextColumn Header="Evidence" Binding="{Binding EvidenceCount}" Width="76"/>
                                <DataGridTextColumn Header="Time" Binding="{Binding TimeRange}" Width="150"/>
                                <DataGridTextColumn Header="Verdict" Binding="{Binding Verdict}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Evidence">
                    <Grid Margin="8" Background="#FF111824">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2.3*"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DataGrid x:Name="EvidenceGrid"
                                  ItemsSource="{Binding EvidencePackets}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  RowStyle="{StaticResource CaseDataGridRowStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding TimeLabel}" Width="105"/>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="88"/>
                                <DataGridTextColumn Header="Detection" Binding="{Binding Detection}" Width="340" MinWidth="280"/>
                                <DataGridTextColumn Header="Actor" Binding="{Binding Actor}" Width="150"/>
                                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="150"/>
                                <DataGridTextColumn Header="Tactic" Binding="{Binding Tactic}" Width="145"/>
                                <DataGridTextColumn Header="ATT&amp;CK" Binding="{Binding TechniqueId}" Width="100"/>
                                <DataGridTextColumn Header="Technique" Binding="{Binding Technique}" Width="210"/>
                                <DataGridTextColumn Header="Why It Matters" Binding="{Binding WhyItMatters}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBox Grid.Row="2"
                                 Text="{Binding SelectedItem.Narrative, ElementName=EvidenceGrid}"
                                 FontFamily="{DynamicResource AppMonoFontFamily}"
                                 Style="{StaticResource CaseReadOnlyTextBoxStyle}"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Timeline">
                    <DataGrid Margin="8"
                              Background="#FF121A17"
                              ItemsSource="{Binding Timeline}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              RowStyle="{StaticResource CaseDataGridRowStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding TimeLabel}" Width="105"/>
                            <DataGridTextColumn Header="Stream" Binding="{Binding Stream}" Width="130"/>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="88"/>
                            <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="220"/>
                            <DataGridTextColumn Header="Actor" Binding="{Binding Actor}" Width="150"/>
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="150"/>
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="IOCs">
                    <DataGrid Margin="8"
                              Background="#FF171421"
                              ItemsSource="{Binding Iocs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="150"/>
                            <DataGridTextColumn Header="Confidence" Binding="{Binding Confidence}" Width="100"/>
                            <DataGridTextColumn Header="Context" Binding="{Binding Context}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Health">
                    <DataGrid Margin="8"
                              Background="#FF1A1414"
                              ItemsSource="{Binding HealthItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="88"/>
                            <DataGridTextColumn Header="Component" Binding="{Binding Component}" Width="240"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="2*"/>
                            <DataGridTextColumn Header="Operator Impact" Binding="{Binding OperatorImpact}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Tuning">
                    <DataGrid Margin="8"
                              Background="#FF181916"
                              ItemsSource="{Binding TuningHints}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="220"/>
                            <DataGridTextColumn Header="Finding" Binding="{Binding Finding}" Width="2*"/>
                            <DataGridTextColumn Header="Recommendation" Binding="{Binding Recommendation}" Width="2*"/>
                            <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Replay / Diff">
                    <DataGrid Margin="8"
                              Background="#FF141824"
                              ItemsSource="{Binding ReplayDiffs}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Scope" Binding="{Binding Scope}" Width="190"/>
                            <DataGridTextColumn Header="Current" Binding="{Binding Current}" Width="250"/>
                            <DataGridTextColumn Header="Baseline" Binding="{Binding Baseline}" Width="250"/>
                            <DataGridTextColumn Header="Interpretation" Binding="{Binding Interpretation}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Report">
                    <TextBox Margin="8"
                             Text="{Binding ReportText}"
                             FontFamily="{DynamicResource AppMonoFontFamily}"
                             Style="{StaticResource CaseReadOnlyTextBoxStyle}"/>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
