<Window x:Class="BlackbirdInterface.SignatureIntelRulesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rules Intel"
        Height="780"
        Width="1240"
        MinHeight="640"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">
    <Grid Margin="14,0,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12,8"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource WinHeaderBrush}"
                MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Rules Intel"
                               FontSize="15"
                               FontWeight="SemiBold"/>
                    <Border Margin="12,0,0,0"
                            Padding="10,3"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource WinPanelBrush}">
                        <TextBlock x:Name="RulesRootBlock"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                    </Border>
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                        Content="&#xE8BB;"
                        Tag="Close"
                        ToolTip="Close"
                        Click="Close_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="12,8"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource WinPanelBrush}">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <Button Content="Reload"
                            Width="94"
                            Margin="0,0,8,0"
                            Click="Reload_Click"/>
                    <Button Content="Import Rule"
                            Width="110"
                            Margin="0,0,8,0"
                            Click="Import_Click"/>
                    <Button Content="New YARA"
                            Width="110"
                            Margin="0,0,8,0"
                            Click="NewYara_Click"/>
                    <Button Content="New SIGMA"
                            Width="110"
                            Margin="0,0,8,0"
                            Click="NewSigma_Click"/>
                    <Button Content="Save"
                            Width="94"
                            Margin="0,0,8,0"
                            Click="Save_Click"/>
                    <Button Content="Delete"
                            Width="94"
                            Click="Delete_Click"/>
                </StackPanel>
                <TextBlock x:Name="StatusBlock"
                           DockPanel.Dock="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WinMutedTextBrush}"
                           Text="Ready"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.55*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{DynamicResource WinHeaderBrush}"
                            Padding="12,8">
                        <TextBlock Text="Loaded Rule Files"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <DataGrid Grid.Row="1"
                              x:Name="RulesGrid"
                              Margin="0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              SelectionChanged="RulesGrid_SelectionChanged"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              GridLinesVisibility="None">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Width="*" Binding="{Binding DisplayName}"/>
                            <DataGridTextColumn Header="Scope" Width="92" Binding="{Binding ScopeLabel}"/>
                            <DataGridTextColumn Header="Type" Width="84" Binding="{Binding Kind}"/>
                            <DataGridTextColumn Header="Rules" Width="72" Binding="{Binding RuleCount}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{DynamicResource WinHeaderBrush}"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Editor"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedRulePathBlock"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource WinMutedTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="User File Name"
                                           Foreground="{DynamicResource WinMutedTextBrush}"/>
                                <TextBox x:Name="RuleFileNameBox"
                                         Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="1"
                             x:Name="RuleEditorBox"
                             Margin="12"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{DynamicResource AppMonoFontFamily}"
                             FontSize="12"
                             TextWrapping="NoWrap"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
