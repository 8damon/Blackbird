<Window x:Class="BlackbirdInterface.TelemetryInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BlackbirdInterface"
        Title="Telemetry Inspector"
        Height="920"
        Width="1440"
        MinHeight="720"
        MinWidth="1180"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="InspectorLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WinMutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="InspectorValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
        </Style>

        <Style x:Key="InspectorTreeItemStyle"
               TargetType="TreeViewItem"
               BasedOn="{StaticResource {x:Type TreeViewItem}}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ThinHorizontalScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Height" Value="7"/>
            <Setter Property="Background" Value="#FF111111"/>
            <Setter Property="Foreground" Value="#FF6A6A6A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   Orientation="Horizontal"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}"
                                                  Background="Transparent"
                                                  BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#FF5C5C5C"
                                           BorderThickness="0"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}"
                                                  Background="Transparent"
                                                  BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FrameTreeViewStyle" TargetType="{x:Type TreeView}" BasedOn="{StaticResource {x:Type TreeView}}">
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="ScrollViewer.PanningMode" Value="HorizontalOnly"/>
        </Style>

        <HierarchicalDataTemplate DataType="{x:Type local:InspectorEventTreeNode}" ItemsSource="{Binding Children}">
            <Border x:Name="EventNodeBorder"
                    Margin="0,0,0,1"
                    Padding="8,6"
                    Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding AccentBrush}"
                    BorderThickness="3,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{Binding TitleBrush}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{DynamicResource WinMutedTextBrush}"
                                   Text="{Binding Subtitle}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Margin="14,0,0,0"
                               VerticalAlignment="Top"
                               Foreground="{Binding AccentBrush}"
                               FontWeight="SemiBold"
                               Text="{Binding RightLabel}"/>
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsLeaf}" Value="True">
                    <Setter TargetName="EventNodeBorder" Property="Background" Value="#FF111111"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type local:InspectorFieldNode}" ItemsSource="{Binding Children}">
            <Border x:Name="NodeBorder" Padding="2,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="NameBlock"
                               Grid.Column="0"
                               Text="{Binding Name}"
                               Foreground="{DynamicResource WinMutedTextBrush}"
                               Margin="2,0,8,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="ValueBlock"
                               Grid.Column="1"
                               Text="{Binding Value}"
                               FontFamily="Consolas"
                               Foreground="{DynamicResource WinTextBrush}"
                               TextWrapping="NoWrap"/>
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="section">
                    <Setter TargetName="NodeBorder" Property="Background" Value="#FF171717"/>
                    <Setter TargetName="NameBlock" Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                    <Setter TargetName="NameBlock" Property="FontWeight" Value="SemiBold"/>
                    <Setter TargetName="ValueBlock" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="line">
                    <Setter TargetName="NameBlock" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ValueBlock" Property="Grid.Column" Value="0"/>
                    <Setter TargetName="ValueBlock" Property="Grid.ColumnSpan" Value="2"/>
                    <Setter TargetName="ValueBlock" Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="note">
                    <Setter TargetName="NameBlock" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ValueBlock" Property="Grid.Column" Value="0"/>
                    <Setter TargetName="ValueBlock" Property="Grid.ColumnSpan" Value="2"/>
                    <Setter TargetName="ValueBlock" Property="Foreground" Value="{DynamicResource WinMutedTextBrush}"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SecondaryWindowTitleBarBorderStyle}"
                MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="HeaderBlock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="Telemetry Inspector"/>
                    <TextBlock x:Name="SummaryBlock"
                               Margin="0,3,0,0"
                               Style="{StaticResource SecondaryWindowSubtitleTextStyle}"
                               Text="No telemetry available"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <TextBlock Style="{StaticResource InspectorLabelStyle}" Margin="0,7,10,0" Text="Visible"/>
                    <TextBlock x:Name="GroupCountBlock" Style="{StaticResource InspectorValueStyle}" Margin="0,7,16,0"/>
                    <TextBlock Style="{StaticResource InspectorLabelStyle}" Margin="0,7,10,0" Text="Occurrences"/>
                    <TextBlock x:Name="OccurrenceCountBlock" Style="{StaticResource InspectorValueStyle}" Margin="0,7,16,0"/>
                    <TextBlock Style="{StaticResource InspectorLabelStyle}" Margin="0,7,10,0" Text="Window"/>
                    <TextBlock x:Name="WindowRangeBlock" Style="{StaticResource InspectorValueStyle}" Margin="0,7,16,0"/>
                    <Button Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                            Content="&#xE921;"
                            Click="WindowMinimize_Click"/>
                    <Button Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                            Content="&#xE922;"
                            Click="WindowMaximize_Click"/>
                    <Button Style="{DynamicResource SecondaryWindowTitleGlyphButtonStyle}"
                            Tag="Close"
                            Content="&#xE8BB;"
                            Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="8,8,8,8"
                Background="{DynamicResource WinHeaderBrush}"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Height="26"
                         VerticalContentAlignment="Center"
                         ToolTip="Search detection, event, actor, target, and decoded details"
                         TextChanged="SearchBox_TextChanged"/>
                <Button x:Name="SeverityFilterButton"
                        Grid.Column="1"
                        Margin="8,0,8,0"
                        Content="Severity: All"
                        MinWidth="112"
                        Click="SeverityFilterButton_Click"/>
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WinMutedTextBrush}"
                           Text="Selection"/>
                <TextBlock x:Name="SelectionBlock"
                           Grid.Column="3"
                           Margin="10,0,10,0"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="SelectionTimeBlock"
                           Grid.Column="4"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WinMutedTextBrush}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.75*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="8,0,0,8"
                    Background="{DynamicResource WinPanelBrush}"
                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                    BorderThickness="1">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Background="#FF141414"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,6">
                        <TextBlock x:Name="DetailCountBlock"
                                   Foreground="{DynamicResource WinMutedTextBrush}"
                                   Text="0 detail rows"/>
                    </Border>
                    <TreeView x:Name="EventTreeView"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemContainerStyle="{StaticResource InspectorTreeItemStyle}"
                              SelectedItemChanged="EventTreeView_SelectedItemChanged"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <Border Grid.Column="2"
                    Margin="0,0,8,8"
                    Background="{DynamicResource WinPanelBrush}"
                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                    BorderThickness="1">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Background="#FF111A28"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,6">
                        <TextBlock Text="Occurrence Detail"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <TreeView x:Name="FieldsTreeView"
                              Style="{StaticResource FrameTreeViewStyle}"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemContainerStyle="{StaticResource InspectorTreeItemStyle}">
                        <TreeView.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinHorizontalScrollBarStyle}"/>
                        </TreeView.Resources>
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Expand All" Click="ExpandAll_Click"/>
                                <MenuItem Header="Collapse All" Click="CollapseAll_Click"/>
                                <Separator/>
                                <MenuItem Header="Copy Visible" Click="CopyVisible_Click"/>
                                <MenuItem Header="Copy Details" Click="CopyRaw_Click"/>
                                <Separator/>
                                <MenuItem Header="Open Correlated Handle Evidence" Click="OpenHandleWindowButton_Click"/>
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
