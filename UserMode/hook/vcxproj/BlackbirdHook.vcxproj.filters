    <ClCompile Include="..\hooks\runtime.cpp">
      <Filter>BlackbirdHook\hooks</Filter>
    </ClCompile>
    <ClCompile Include="..\hooks\nt.cpp">
      <Filter>BlackbirdHook\hooks</Filter>
    </ClCompile>
    <ClCompile Include="..\instrument\stacktrace.cpp">
      <Filter>BlackbirdHook\instrument</Filter>
    </ClCompile>
    <ClCompile Include="..\instrument\unlink.cpp">
      <Filter>BlackbirdHook\instrument</Filter>
    </ClCompile>
    <ClCompile Include="..\instrument\bk.cpp">
      <Filter>BlackbirdHook\instrument</Filter>
