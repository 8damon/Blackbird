<Window x:Class="SleepwalkerInterface.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostics Output"
        Height="720"
        Width="1080"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WinBgBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Debug / Console Output" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock x:Name="TargetBlock"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource WinMutedTextBrush}"/>
        </DockPanel>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="1"
                Padding="6"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Live State Snapshot"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <TextBox Grid.Row="1"
                         x:Name="StateBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="11"/>
            </Grid>
        </Border>

        <TextBox Grid.Row="2"
                 x:Name="OutputBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"/>

        <DockPanel Grid.Row="3" Margin="0,10,0,0" LastChildFill="False">
            <Button Content="Refresh State"
                    DockPanel.Dock="Left"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="RefreshState_Click"/>
            <Button Content="Clear"
                    DockPanel.Dock="Left"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="Clear_Click"/>
            <Button Content="Close"
                    DockPanel.Dock="Right"
                    Padding="12,4"
                    Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
