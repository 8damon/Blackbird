<Window x:Class="SleepwalkerInterface.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Loading"
        Width="480"
        Height="190"
        ResizeMode="NoResize"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#FF000000">

    <Border Margin="1"
            BorderBrush="#FF2B2B2B"
            BorderThickness="1"
            Background="#FF101010">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="Sleepwalker"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFE6E6E6"/>
                <TextBlock x:Name="StatusBlock"
                           Text="Initializing..."
                           Margin="0,6,0,0"
                           Foreground="#FF9A9A9A"/>
            </StackPanel>

            <ProgressBar Grid.Row="1"
                         x:Name="LoadBar"
                         Height="14"
                         Margin="0,14,0,0"
                         Minimum="0"
                         Maximum="100"
                         Background="#FF1C1C1C"
                         Foreground="#FF4D8D4D"
                         Value="8"/>

            <TextBlock Grid.Row="2"
                       x:Name="PercentBlock"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Right"
                       Foreground="#FF9A9A9A"/>
        </Grid>
    </Border>
</Window>
