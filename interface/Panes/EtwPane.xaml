<UserControl x:Class="SleepwalkerInterface.EtwPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WinPanelBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource EtwHeaderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="10,0,8,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Text="Sleepwalker ETW Feed"/>

            <TextBlock x:Name="SummaryBlock"
                       Grid.Column="1"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource WinMutedTextBrush}"
                       Text="No ETW events yet"/>

            <Button Grid.Column="2"
                    x:Name="EtwBtnReorder"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⇅"
                    Width="22"
                    Height="22"
                    ToolTip="Reorder ETW/Heuristics panes"
                    Click="EtwBtnReorder_Click"/>
            <Button Grid.Column="3"
                    x:Name="EtwBtnFloat"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⧉"
                    Width="22"
                    Height="22"
                    ToolTip="Float / re-dock pane"
                    Click="EtwBtnFloat_Click"/>
            <Button Grid.Column="4"
                    x:Name="EtwBtnClose"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="✕"
                    Width="22"
                    Height="22"
                    Margin="4,4,6,4"
                    ToolTip="Hide pane"
                    Click="EtwBtnClose_Click"/>
        </Grid>

        <Border Grid.Row="1"
                Margin="4"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="1">
            <Grid>
                <DataGrid x:Name="EventsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          CanUserResizeRows="False"
                          ColumnHeaderHeight="24"
                          RowHeight="22"
                          MouseDoubleClick="EventsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Event" Width="260" Binding="{Binding Event}"/>
                        <DataGridTextColumn Header="Severity" Width="92" Binding="{Binding Severity}"/>
                        <DataGridTextColumn Header="Hits" Width="72" Binding="{Binding Hits}"/>
                        <DataGridTextColumn Header="Detection" Width="*" Binding="{Binding Detection}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="NoDataOverlay"
                        Background="{DynamicResource NoDataOverlayBrush}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <TextBlock Text="NO DATA"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WinTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.72"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
