<UserControl x:Class="BlackbirdInterface.EventsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BlackbirdInterface"
             Background="{DynamicResource WinPanelBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0"/>
            <RowDefinition x:Name="EventLogRow" Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pane header -->
        <Grid Grid.Row="0"
              Background="{DynamicResource EventsHeaderBrush}"
              MouseLeftButtonDown="Header_MouseLeftButtonDown"
              MouseMove="Header_MouseMove"
              MouseLeftButtonUp="Header_MouseLeftButtonUp">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Events"
                       Margin="10,0,10,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"/>

            <TextBlock x:Name="HeaderStatsBlock"
                       Grid.Column="1"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource WinMutedTextBrush}"
                       Text="View 0 | Total 0 | 0.0/s"
                       TextTrimming="CharacterEllipsis"/>

            <ComboBox x:Name="LaneFilterBox"
                      Grid.Column="2"
                      Margin="0,4"
                      Style="{DynamicResource PaneFilterComboStyle}"
                      ItemContainerStyle="{DynamicResource PaneFilterComboItemStyle}"
                      SelectionChanged="LaneFilterBox_SelectionChanged"/>

            <Button Grid.Column="3"
                    x:Name="BtnSettings"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⚙"
                    Width="22"
                    Height="22"
                    Click="BtnSettings_Click"/>
            <Button Grid.Column="4"
                    x:Name="BtnLogPopout"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⇱"
                    Width="22"
                    Height="22"
                    ToolTip="Detach event log"
                    Click="BtnLogPopout_Click"/>
            <Button Grid.Column="5"
                    x:Name="BtnFloat"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⧉"
                    Width="22"
                    Height="22"
                    Click="BtnFloat_Click"/>
            <Button Grid.Column="6"
                    x:Name="BtnClose"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="✕"
                    Width="22"
                    Height="22"
                    Margin="4,4,6,4"
                    Click="BtnClose_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="8"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                    BorderThickness="0,0,0,1">
                <local:TimelineControl x:Name="EventTimeline"
                                       AxisHeight="0"
                                       ViewDurationSeconds="120"
                                       ViewStartSeconds="0"/>
            </Border>

            <ScrollBar x:Name="TimelineVerticalScroll"
                       Grid.Row="0"
                       Orientation="Vertical"
                       Minimum="0"
                       SmallChange="22"
                       LargeChange="120"
                       Visibility="Collapsed"
                       Width="0"/>

            <local:TimelineControl x:Name="EventTimelineAxis"
                                   Grid.Row="1"
                                   IsAxisOnly="True"
                                   AxisHeight="28"
                                   ViewDurationSeconds="{Binding ViewDurationSeconds, ElementName=EventTimeline}"
                                   ViewStartSeconds="{Binding ViewStartSeconds, ElementName=EventTimeline}"
                                   CaptureStartUtc="{Binding CaptureStartUtc, ElementName=EventTimeline}"
                                   IsHitTestVisible="False"/>

            <ScrollBar x:Name="TimelineScroll"
                       Grid.Row="2"
                       Orientation="Horizontal"
                       Minimum="0"
                       SmallChange="1"
                       LargeChange="5"
                       Height="7"
                       VerticalAlignment="Stretch"
                       Margin="176,0,6,0"
                       Background="{DynamicResource WinSubtleBorderBrush}"/>
        </Grid>

        <Border Grid.Row="2" Visibility="Collapsed"/>

        <Border x:Name="EventLogBorder"
                Grid.Row="3"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="0,1,0,0"
                Margin="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource WinHeaderBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="8,0">
                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Event Log" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </DockPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          x:Name="EventGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          SelectionMode="Single"
                          ColumnHeaderHeight="24"
                          RowHeight="22"
                          CanUserResizeRows="False"
                          MouseDoubleClick="EventGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp"
                                            Binding="{Binding TimestampUtc, StringFormat=HH:mm:ss.fff}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="110"/>
                        <DataGridTextColumn Header="SubType" Binding="{Binding SubType}" Width="130"/>
                        <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="70"/>
                        <DataGridTextColumn Header="TID" Binding="{Binding TID}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

        <Border x:Name="EventsNoDataOverlay"
                Grid.Row="1"
                Grid.RowSpan="3"
                Margin="0"
                Background="{DynamicResource NoDataOverlayBrush}"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <TextBlock Text="NO DATA"
                       FontSize="48"
                       FontWeight="Bold"
                       Opacity="0.72"
                       Foreground="{DynamicResource WinTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>

