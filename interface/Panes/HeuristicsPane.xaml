<UserControl x:Class="SleepwalkerInterface.HeuristicsPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource WinPanelBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{DynamicResource HeuristicsHeaderBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Margin="10,0,8,0"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       FontSize="12"
                       Text="Heuristics"/>

            <TextBlock x:Name="SummaryBlock"
                       Grid.Column="1"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource WinMutedTextBrush}"
                       Text="No detections yet"/>

            <Button Grid.Column="2"
                    x:Name="HeurBtnReorder"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⇅"
                    Width="22"
                    Height="22"
                    ToolTip="Reorder ETW/Heuristics panes"
                    Click="HeurBtnReorder_Click"/>
            <Button Grid.Column="3"
                    x:Name="HeurBtnFloat"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⧉"
                    Width="22"
                    Height="22"
                    ToolTip="Float / re-dock pane"
                    Click="HeurBtnFloat_Click"/>
            <Button Grid.Column="4"
                    x:Name="HeurBtnClose"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="✕"
                    Width="22"
                    Height="22"
                    Margin="4,4,6,4"
                    ToolTip="Hide pane"
                    Click="HeurBtnClose_Click"/>
        </Grid>

        <Border Grid.Row="1"
                Margin="4"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="1">
            <Grid>
                <DataGrid x:Name="HeuristicsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          BorderThickness="0"
                          CanUserResizeRows="False"
                          ColumnHeaderHeight="24"
                          RowHeight="22"
                          MouseDoubleClick="HeuristicsGrid_MouseDoubleClick">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource WinSubtleBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                    <Setter Property="Background" Value="#2A5E1E1E"/>
                                    <Setter Property="BorderBrush" Value="#FFCC5A5A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                    <Setter Property="Background" Value="#2A5E1E1E"/>
                                    <Setter Property="BorderBrush" Value="#FFCC5A5A"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                    <Setter Property="Background" Value="#2A5E3A1E"/>
                                    <Setter Property="BorderBrush" Value="#FFD59A56"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Low">
                                    <Setter Property="Background" Value="#2A5E521E"/>
                                    <Setter Property="BorderBrush" Value="#FFD7C55F"/>
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#3A6EA6D8"/>
                                    <Setter Property="BorderBrush" Value="#FF6EA6D8"/>
                                    <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Event" Width="260" Binding="{Binding Event}"/>
                        <DataGridTextColumn Header="Hits" Width="72" Binding="{Binding Hits}"/>
                        <DataGridTextColumn Header="Detection" Width="*" Binding="{Binding Detection}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Border x:Name="HeuristicsNoDataOverlay"
                        Background="{DynamicResource NoDataOverlayBrush}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <TextBlock Text="NO DATA"
                               FontSize="40"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WinTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.72"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
