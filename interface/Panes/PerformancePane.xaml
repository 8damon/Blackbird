<UserControl x:Class="SleepwalkerInterface.PerformancePane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SleepwalkerInterface"
             Background="{DynamicResource WinPanelBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Background="{DynamicResource PerformanceHeaderBrush}"
              MouseLeftButtonDown="Header_MouseLeftButtonDown"
              MouseMove="Header_MouseMove"
              MouseLeftButtonUp="Header_MouseLeftButtonUp">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource PerformanceHeaderAccentBrush}"/>

            <TextBlock Grid.Column="1"
                       Text="Performance"
                       Margin="8,0,10,0"
                       FontWeight="SemiBold"
                       FontSize="12"
                       VerticalAlignment="Center"/>

            <TextBlock x:Name="PerfSubTitle"
                       Grid.Column="2"
                       HorizontalAlignment="Left"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource WinMutedTextBrush}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <Button Grid.Column="3"
                    x:Name="PerfBtnReorder"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⇅"
                    Width="22"
                    Height="22"
                    ToolTip="Reorder panes"
                    Click="PerfBtnReorder_Click"/>
            <Button Grid.Column="4"
                    x:Name="PerfBtnFloat"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="⧉"
                    Width="22"
                    Height="22"
                    Click="PerfBtnFloat_Click"/>
            <Button Grid.Column="5"
                    x:Name="PerfBtnClose"
                    Style="{DynamicResource PaneIconButtonStyle}"
                    Content="✕"
                    Width="22"
                    Height="22"
                    Margin="4,4,6,4"
                    Click="PerfBtnClose_Click"/>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*" MinHeight="190"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*" MinHeight="150"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Visibility="Collapsed"
                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                    BorderThickness="1"
                    Padding="8,5"
                    Margin="0,0,0,2"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ToggleButton x:Name="TimeTravelToggle"
                                  Content="Time Travel"
                                  Padding="8,2"
                                  VerticalAlignment="Center"
                                  Checked="TimeTravelToggle_Checked"
                                  Unchecked="TimeTravelToggle_Unchecked"/>

                    <Slider x:Name="TimeTravelSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="0"
                            Value="0"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            IsEnabled="False"
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            ValueChanged="TimeTravelSlider_ValueChanged"/>

                    <TextBlock x:Name="TimeTravelStampBlock"
                               Grid.Column="2"
                               Text="LIVE"
                               Foreground="{DynamicResource WinMutedTextBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ClipToBounds="True" Margin="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <local:PerformanceChartControl x:Name="CpuChart" Grid.Column="0" Title="CPU" Margin="0,0,6,0"/>
                <local:PerformanceChartControl x:Name="DiskChart" Grid.Column="1" Title="Disk IO" Margin="0,0,6,0"/>
                <local:PerformanceChartControl x:Name="RamChart" Grid.Column="2" Title="RAM" Margin="0,0,6,0"/>
                <Border Grid.Column="3"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        Background="{DynamicResource WinPanelBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource WinHeaderBrush}"
                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,0">
                            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                <TextBlock x:Name="NetworkPaneTitle"
                                           Text="Network Traffic"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button x:Name="NetworkViewSwitchButton"
                                        DockPanel.Dock="Right"
                                        Content="Peers"
                                        MinWidth="44"
                                        MinHeight="20"
                                        Height="20"
                                        Padding="5,0"
                                        Margin="6,0,0,0"
                                        FontSize="11"
                                        VerticalAlignment="Center"
                                        ToolTip="Toggle traffic/peers view"
                                        Click="NetworkViewSwitchButton_Click"/>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <local:PerformanceChartControl x:Name="NetChart"
                                                           Title="Network"
                                                           Visibility="Visible"/>
                            <DataGrid x:Name="NetworkPeersGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      CanUserResizeRows="False"
                                      ColumnHeaderHeight="24"
                                      RowHeight="22"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Remote IP" Width="150" Binding="{Binding RemoteAddress}"/>
                                    <DataGridTextColumn Header="DNS" Width="220" Binding="{Binding DnsName}"/>
                                    <DataGridTextColumn Header="Proto" Width="70" Binding="{Binding Protocol}"/>
                                    <DataGridTextColumn Header="State" Width="120" Binding="{Binding State}"/>
                                    <DataGridTextColumn Header="Hits" Width="70" Binding="{Binding ConnectionCount}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="2"
                          Height="2"
                          Background="{DynamicResource WinSubtleBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Top threads -->
                <Border Grid.Column="0"
                        Background="{DynamicResource WinPanelBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        Padding="0"
                        ClipToBounds="True"
                        Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource WinHeaderBrush}"
                                BorderBrush="{DynamicResource WinBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="8,0">
                            <DockPanel LastChildFill="True" VerticalAlignment="Center">
                                <TextBlock Text="Top Threads" FontWeight="SemiBold"/>
                                <ToggleButton x:Name="ThreadLifecycleToggle"
                                              DockPanel.Dock="Right"
                                              Margin="8,0,0,0"
                                              Padding="8,2"
                                              VerticalAlignment="Center"
                                              Checked="ThreadLifecycleToggle_Checked"
                                              Unchecked="ThreadLifecycleToggle_Unchecked"
                                              Content="Lifecycle"/>
                            </DockPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="ThreadsGrid"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      Margin="0"
                                      ColumnHeaderHeight="24"
                                      RowHeight="22"
                                      CanUserResizeRows="False"
                                      MouseDoubleClick="ThreadsGrid_MouseDoubleClick">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuspended}" Value="True">
                                                <Setter Property="Foreground" Value="#FFF8E9AF"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                                <Setter Property="Foreground" Value="#FFC6D9FF"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="TID" Binding="{Binding Tid}" Width="72"/>
                                    <DataGridTextColumn Header="CPU ms" Binding="{Binding CpuMs}" Width="90"/>
                                    <DataGridTextColumn Header="State" Binding="{Binding State}" Width="160"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding ThreadKind}" Width="150"/>
                                    <DataGridTextColumn Header="Start" Binding="{Binding StartTime}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <DataGrid x:Name="ThreadLifecycleGrid"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      Margin="0"
                                      ColumnHeaderHeight="24"
                                      RowHeight="22"
                                      Visibility="Collapsed"
                                      CanUserResizeRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp}" Width="86"/>
                                    <DataGridTextColumn Header="Event" Binding="{Binding EventKind}" Width="76"/>
                                    <DataGridTextColumn Header="TID" Binding="{Binding Tid}" Width="72"/>
                                    <DataGridTextColumn Header="Creator" Binding="{Binding CreatorPid}" Width="82"/>
                                    <DataGridTextColumn Header="Flags" Binding="{Binding Flags}" Width="86"/>
                                    <DataGridTextColumn Header="Start" Binding="{Binding StartAddress}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border x:Name="ThreadsNoDataOverlay"
                                    Background="{DynamicResource NoDataOverlayBrush}"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="NO DATA"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Opacity="0.72"
                                               Foreground="{DynamicResource WinTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ThreadsNoDataMessageBlock"
                                               Margin="0,6,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource WinMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Text="No thread data in the selected range."/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <Border Grid.Column="2"
                        Background="{DynamicResource WinPanelBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        Padding="0">
                    <Grid x:Name="ProcessDetailsLayout" SizeChanged="ProcessDetailsLayout_SizeChanged">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ModulesColumn" Width="3*"/>
                            <ColumnDefinition x:Name="DetailsSplitterColumn" Width="2"/>
                            <ColumnDefinition x:Name="MemoryColumn" Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="0"/>
                            <RowDefinition Height="0"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="ModulesPanel"
                                Grid.Row="0"
                                Grid.Column="0"
                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                BorderThickness="0,0,1,0"
                                Padding="0">
                            <TabControl Padding="0">
                                <TabItem Header="Modules">
                                    <DataGrid x:Name="ModulesGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              MouseDoubleClick="ModulesGrid_MouseDoubleClick">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Module" Binding="{Binding Name}" Width="170"/>
                                            <DataGridTextColumn Header="Base" Binding="{Binding BaseAddress}" Width="130"/>
                                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="85"/>
                                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>

                                <TabItem Header="PE">
                                    <DataGrid x:Name="PeInfoGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="220"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                            </TabControl>
                        </Border>

                        <GridSplitter x:Name="DetailsSplitter"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Width="2"
                                      Background="{DynamicResource WinSubtleBorderBrush}"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>

                        <Border x:Name="MemoryPanel"
                                Grid.Row="0"
                                Grid.Column="2"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource WinHeaderBrush}"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,0">
                                    <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                        <TextBlock Text="Memory"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="MemoryInspectorToggle"
                                                      Margin="8,0,0,0"
                                                      Padding="8,2"
                                                      VerticalAlignment="Center"
                                                      Checked="MemoryInspectorToggle_Checked"
                                                      Unchecked="MemoryInspectorToggle_Unchecked"
                                                      Content="Inspector"/>
                                        <ToggleButton x:Name="MemoryViewToggle"
                                                      Margin="8,0,0,0"
                                                      Padding="8,2"
                                                      VerticalAlignment="Center"
                                                      Checked="MemoryViewToggle_Checked"
                                                      Unchecked="MemoryViewToggle_Unchecked"
                                                      Content="Treemap"/>
                                    </DockPanel>
                                </Border>

                                <Grid Grid.Row="1">
                                    <DataGrid x:Name="MemoryGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              Visibility="Collapsed">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Metric" Binding="{Binding Metric}" Width="220"/>
                                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <DataGrid x:Name="MemoryInspectorGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              BorderThickness="0"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="22"
                                              Visibility="Collapsed">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Base" Binding="{Binding BaseAddress}" Width="132"/>
                                            <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="92"/>
                                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="82"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="82"/>
                                            <DataGridTextColumn Header="Protect" Binding="{Binding Protect}" Width="180"/>
                                            <DataGridTextColumn Header="Class" Binding="{Binding Category}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Grid x:Name="MemoryTreemapHost"
                                          Visibility="Visible">
                                        <Border BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                BorderThickness="0"
                                                Background="{DynamicResource WinPanelBrush}">
                                            <Canvas x:Name="MemoryTreemapCanvas"/>
                                        </Border>

                                        <TextBlock x:Name="MemoryTreemapNoData"
                                                   Text="NO DATA"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource WinMutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </Grid>

                                    <Border x:Name="MemoryNoDataOverlay"
                                            Background="{DynamicResource NoDataOverlayBrush}"
                                            Visibility="Collapsed"
                                            IsHitTestVisible="False">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="NO DATA"
                                                       FontSize="28"
                                                       FontWeight="Bold"
                                                       Opacity="0.72"
                                                       Foreground="{DynamicResource WinTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock x:Name="MemoryNoDataMessageBlock"
                                                       Margin="0,6,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource WinMutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       Text="No memory data in the selected range."/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
