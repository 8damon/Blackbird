<Window x:Class="SleepwalkerInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SleepwalkerInterface"
        Title="Sleepwalker"
        Height="908"
        Width="1494"
        MinHeight="760"
        MinWidth="1220"
        WindowState="Maximized"
        Background="{DynamicResource WinBgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ProcessTabStripStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource WinHeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinBorderBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                ClipToBounds="True">
                            <TabPanel IsItemsHost="True"
                                      Margin="2,0,2,0"
                                      ClipToBounds="True"
                                      Background="{TemplateBinding Background}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeSelectorStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource WinHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="SelectorBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>

                            <ContentPresenter Margin="8,1,26,1"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False"/>

                            <Path HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  Data="M 0 0 L 8 0 L 4 4 Z"
                                  Fill="{DynamicResource WinTextBrush}"
                                  IsHitTestVisible="False"/>

                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press"/>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Focusable="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade">
                                <Border Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource WinPanelBrush}"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{DynamicResource WinAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="SelectorBorder" Property="BorderBrush" Value="{DynamicResource WinAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandBarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource CommandBarButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinSubtleBorderBrush}"/>
        </Style>

        <Style x:Key="StatusLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource WinMutedTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{DynamicResource WinBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- Command bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource CommandBarBackgroundBrush}"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox x:Name="PidBox" Visibility="Collapsed"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Select Target" Click="FindProcess_Click"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Connect" Click="Connect_Click"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Launch" Click="Launch_Click"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Preflight" Click="Preflight_Click"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Driver Start" Click="DriverStart_Click"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Driver Stop" Click="DriverStop_Click"/>
                    <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Controller Restart" Click="ControllerRestart_Click"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="1"
                        Margin="0,2"
                        Background="{DynamicResource WinSubtleBorderBrush}"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Theme"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource WinMutedTextBrush}"/>
                    <ComboBox x:Name="ThemeSelector"
                              Width="110"
                              Margin="0,0,10,0"
                              Style="{DynamicResource ThemeSelectorStyle}"
                              Background="{DynamicResource WinHeaderBrush}"
                              Foreground="{DynamicResource WinTextBrush}"
                              SelectionChanged="ThemeSelector_SelectionChanged">
                        <ComboBoxItem Content="Auto"/>
                        <ComboBoxItem Content="Dark"/>
                        <ComboBoxItem Content="Light"/>
                    </ComboBox>
                    <TextBlock x:Name="StatusBlock"
                               Text="Status: Disconnected"
                               Margin="0,0,18,0"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                    <TextBlock x:Name="RangeBlock"
                               Text="Range:"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource WinTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Workspace: explorer + docked panes -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="220"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Explorer -->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource WinHeaderBrush}"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,0">
                        <TextBlock Text="GRAPH EXPLORER"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="GraphExplorer"
                             Background="{DynamicResource WinPanelBrush}"
                             Style="{DynamicResource ExplorerListStyle}"
                             ItemContainerStyle="{DynamicResource ExplorerItemStyle}"
                             SelectionMode="Single"
                             PreviewMouseLeftButtonUp="GraphExplorer_PreviewMouseLeftButtonUp">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        Height="96"
                                        Background="{DynamicResource WinPanelBrush}">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Opacity" Value="0.35"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <Rectangle Fill="{DynamicResource ExplorerPreviewBackgroundBrush}"/>

                                        <local:SparklinePreviewControl Margin="6"
                                                                       Values="{Binding PreviewValues}"
                                                                       Stroke="{Binding AccentBrush}"/>

                                        <Border x:Name="NoDataBadge"
                                                Margin="6"
                                                Background="{DynamicResource NoDataOverlayBrush}"
                                                Visibility="Collapsed">
                                            <TextBlock Text="NO DATA"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       Opacity="0.72"
                                                       Foreground="{DynamicResource WinTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="8,8,0,0"
                                                Background="{DynamicResource ExplorerOverlayBrush}"
                                                Padding="6,2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </Border>

                                        <Border x:Name="DetailsBadge"
                                                Margin="6,0,6,6"
                                                VerticalAlignment="Bottom"
                                                Background="{DynamicResource ExplorerOverlayBrush}"
                                                Padding="6,3"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DetailPrimary}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DetailSecondary}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource WinMutedTextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasData}" Value="False">
                                        <Setter TargetName="NoDataBadge" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ShowDetails}" Value="True">
                                        <Setter TargetName="DetailsBadge" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                        <Setter TargetName="DetailsBadge" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="2"
                          Background="{DynamicResource WinSubtleBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <!-- Docked panes + process tabs -->
            <Grid Grid.Column="2" Margin="2,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="IpcUplinkColumn" Width="0"/>
                    <ColumnDefinition x:Name="IpcUplinkSplitterColumn" Width="0"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="IntelligenceSplitterColumn" Width="2"/>
                    <ColumnDefinition x:Name="IntelligenceColumn" Width="430"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        x:Name="IpcUplinkDockBorder"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        MinWidth="360"
                        Margin="0,0,3,0"
                        Background="{DynamicResource WinPanelBrush}"
                        Visibility="Collapsed">
                    <local:IpcUplinkPane x:Name="IpcUplinkPaneHost"/>
                </Border>

                <GridSplitter Grid.Column="1"
                              x:Name="IpcUplinkSplitter"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Visibility="Collapsed"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource WinHeaderBrush}"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,1,1,0"
                            Padding="4,0">
                        <DockPanel LastChildFill="True">
                            <Button Content="New Tab"
                                    DockPanel.Dock="Right"
                                    Margin="6,2,0,2"
                                    Padding="10,2"
                                    Click="NewProcessTab_Click"/>

                            <TabControl x:Name="ProcessTabs"
                                        Style="{DynamicResource ProcessTabStripStyle}"
                                        BorderThickness="0"
                                        Background="{DynamicResource WinHeaderBrush}"
                                        SelectionChanged="ProcessTabs_SelectionChanged">
                                <TabControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="{Binding Title}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"
                                                       MaxWidth="220"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Content="x"
                                                    DockPanel.Dock="Right"
                                                    Width="16"
                                                    Height="16"
                                                    Padding="0"
                                                    Margin="0"
                                                    MinWidth="16"
                                                    MinHeight="16"
                                                    Tag="{Binding}"
                                                    Click="CloseProcessTab_Click"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                            </TabControl>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" x:Name="DockGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4*"/>
                            <RowDefinition Height="2"/>
                            <RowDefinition Height="5*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" x:Name="EventsPaneRow" Margin="0,0,0,3">
                            <Border x:Name="EventsDockBorder"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource WinPanelBrush}">
                                <local:EventsPane x:Name="EventsPaneHost"/>
                            </Border>

                            <Border x:Name="CollapsedEventsBar"
                                    Visibility="Collapsed"
                                    Height="28"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource EventsHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MouseLeftButtonUp="CollapsedEventsBar_MouseLeftButtonUp">
                                <Grid>
                                    <TextBlock Text="Events (collapsed)"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Click to open"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource WinMutedTextBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Row="1"
                                      x:Name="DockSplitter"
                                      Height="2"
                                      Background="{DynamicResource WinSubtleBorderBrush}"
                                      HorizontalAlignment="Stretch"
                                      ShowsPreview="True"/>

                        <Grid Grid.Row="2" x:Name="PerformancePaneRow" Margin="0,3,0,0">
                            <Border x:Name="PerformanceDockBorder"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource WinPanelBrush}">
                                <local:PerformancePane x:Name="PerformancePaneHost"/>
                            </Border>

                            <Border x:Name="CollapsedPerformanceBar"
                                    Visibility="Collapsed"
                                    Height="28"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource PerformanceHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MouseLeftButtonUp="CollapsedPerformanceBar_MouseLeftButtonUp">
                                <Grid>
                                    <TextBlock Text="Performance (collapsed)"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Click to open"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource WinMutedTextBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border x:Name="DockPreviewTop"
                                Grid.Row="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                Margin="6"
                                BorderThickness="2"
                                BorderBrush="#CC8FC7FF"
                                Background="#223A6EA5"/>

                        <Border x:Name="DockPreviewBottom"
                                Grid.Row="2"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                Margin="6"
                                BorderThickness="2"
                                BorderBrush="#CC8FC7FF"
                                Background="#223A6EA5"/>
                    </Grid>
                </Grid>

                <GridSplitter Grid.Column="3"
                              x:Name="IntelligenceSplitter"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <Grid Grid.Column="4" x:Name="IntelligenceDock">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            x:Name="EtwDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,0,3"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:EtwPane x:Name="EtwPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="2"
                            x:Name="HeuristicsDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1"
                            Margin="0,3,0,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:HeuristicsPane x:Name="HeuristicsPaneHost"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                x:Name="BottomStatusBar"
                Background="{DynamicResource WinHeaderBrush}"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        x:Name="BottomStatusButton"
                        Style="{DynamicResource StatusLinkButtonStyle}"
                        Click="Diagnostics_Click"
                        ToolTip="Open diagnostics">
                    <TextBlock x:Name="UplinkStatusBlock"
                               Text="UPLINK CHECKING..."
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource WinMutedTextBrush}"/>
                </Button>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Diagnostics"
                            Click="Diagnostics_Click"/>
                    <Button Content="Reset Dock"
                            Margin="8,0,0,0"
                            Click="ResetDock_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
