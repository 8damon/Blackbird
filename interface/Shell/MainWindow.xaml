<Window x:Class="BlackbirdInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BlackbirdInterface"
        Title="BLACKBIRD | IDLE"
        Height="908"
        Width="1494"
        MinHeight="760"
        MinWidth="1220"
        WindowState="Maximized"
        Background="{DynamicResource WinBgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ProcessTabStripStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource WinHeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinBorderBrush}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                ClipToBounds="True">
                            <TabPanel IsItemsHost="True"
                                      Margin="2,0,2,0"
                                      ClipToBounds="True"
                                      Background="{TemplateBinding Background}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandBarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource CommandBarButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinSubtleBorderBrush}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="MinHeight" Value="22"/>
        </Style>

        <Style x:Key="ToolbarOpenWindowComboStyle" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinSubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="OuterBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Margin="6,0,4,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                    <ToggleButton x:Name="DropDownToggle"
                                                  Grid.Column="1"
                                                  Focusable="False"
                                                  ClickMode="Press"
                                                  BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                  BorderThickness="1,0,0,0"
                                                  Background="{DynamicResource WinHeaderBrush}"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <Path Width="8"
                                              Height="5"
                                              Stretch="Fill"
                                              Fill="{DynamicResource WinTextBrush}"
                                              Data="M 0 0 L 4 5 L 8 0 Z"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource WinPanelBrush}"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer Margin="0"
                                                  Background="{DynamicResource WinPanelBrush}"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource InputHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandRibbonTabItemStyle" TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource WinMutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6,14,5"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="TabBackground"
                                    Background="Transparent"
                                    CornerRadius="2"/>
                            <Border x:Name="Underline"
                                    Height="2"
                                    VerticalAlignment="Bottom"
                                    Margin="10,0,10,0"
                                    Background="{DynamicResource WinAccentBrush}"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0.4"/>
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBackground" Property="Background" Value="{DynamicResource WinPanelBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBackground" Property="Background" Value="{DynamicResource WinPanelBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="HoldEnd">
                                            <DoubleAnimation Storyboard.TargetName="Underline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.14"/>
                                            <DoubleAnimation Storyboard.TargetName="Underline"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1"
                                                             Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="Stop">
                                            <DoubleAnimation Storyboard.TargetName="Underline"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="Underline"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="0.4"
                                                             Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource WinMutedTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTimeTravelTrackButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="#FF202020"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTimeTravelThumbStyle" TargetType="Thumb">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#FFB8B8B8"
                                BorderBrush="#FF5A5A5A"
                                BorderThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopTimeTravelSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TopTimeTravelTrackButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource TopTimeTravelThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource TopTimeTravelTrackButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

        <Grid x:Name="RootGrid" Background="{DynamicResource WinBgBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="0"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Grid Grid.Row="0" Visibility="Collapsed">
            <Border x:Name="ProcessStateBadge"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Background="Transparent"
                    HorizontalAlignment="Left"
                    Visibility="Collapsed">
                <TextBlock x:Name="ProcessStateBlock"
                           Text="Disconnected"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource WinMutedTextBrush}"/>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource CommandBarBackgroundBrush}"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Visibility="Collapsed"
                        BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="4,0">
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="Open Session..." Click="OpenSession_Click"/>
                            <MenuItem Header="Import Session..." Click="ImportSession_Click"/>
                            <MenuItem Header="Save Session As..." Click="SaveSessionAs_Click"/>
                            <MenuItem Header="Export Session..." Click="ExportSession_Click"/>
                        </MenuItem>
                        <MenuItem Header="Home">
                            <MenuItem Header="Select Target..." Click="FindProcess_Click"/>
                            <MenuItem Header="Connect" Click="Connect_Click"/>
                            <MenuItem Header="Launch" Click="Launch_Click"/>
                            <Separator/>
                            <MenuItem Header="Preflight" Click="Preflight_Click"/>
                            <MenuItem Header="Driver Start" Click="DriverStart_Click"/>
                            <MenuItem Header="Driver Stop" Click="DriverStop_Click"/>
                            <MenuItem Header="Controller Restart" Click="ControllerRestart_Click"/>
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem Header="Docking: Events Float" Click="DockEventsToggle_Click"/>
                            <MenuItem Header="Docking: Perf Float" Click="DockPerfToggle_Click"/>
                            <MenuItem Header="Docking: ETW Float" Click="DockEtwToggle_Click"/>
                            <MenuItem Header="Docking: Heur Float" Click="DockHeurToggle_Click"/>
                            <Separator/>
                            <MenuItem Header="Docking: Swap Main" Click="DockSwapMain_Click"/>
                            <MenuItem Header="Docking: Swap Intel" Click="DockSwapIntel_Click"/>
                            <MenuItem Header="Docking: Redock All" Click="ResetDock_Click"/>
                            <Separator/>
                            <MenuItem x:Name="SwitchViewMenuItem" Header="Switch View (API)" Click="SwitchView_Click"/>
                        </MenuItem>
                    </Menu>
                </Border>

                <Grid Grid.Row="1" Margin="6,4,6,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="2"
                            Background="{DynamicResource WinHeaderBrush}">
                        <TabControl Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    SelectedIndex="0">
                            <TabControl.Resources>
                                <Style TargetType="TabItem" BasedOn="{StaticResource CommandRibbonTabItemStyle}"/>
                            </TabControl.Resources>

                            <TabItem Header="Home">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="2,0">
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,6">
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Select Target" Click="FindProcess_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Reconnect" Click="Connect_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Launch" Click="Launch_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Diagnostics" Click="Diagnostics_Click"/>
                                        <Separator Margin="8,0"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Preflight" Click="Preflight_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Driver Start" Click="DriverStart_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Driver Stop" Click="DriverStop_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Controller" Click="ControllerRestart_Click"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="View">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="2,0">
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,6">
                                        <TextBlock Text="Open Window"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                                        <ComboBox x:Name="ToolbarViewMenu"
                                                  Style="{StaticResource ToolbarOpenWindowComboStyle}"
                                                  Width="184"
                                                  Height="24"
                                                  Margin="0,0,6,0"
                                                  VerticalAlignment="Center"
                                                  DropDownOpened="ToolbarViewMenu_DropDownOpened"
                                                  SelectionChanged="ToolbarViewMenu_SelectionChanged"
                                                  SelectedIndex="0">
                                            <ComboBoxItem Content="Open Window..."/>
                                            <ComboBoxItem Content="Events Pane" Tag="events"/>
                                            <ComboBoxItem Content="Performance Pane" Tag="performance"/>
                                            <ComboBoxItem Content="ETW Pane" Tag="etw"/>
                                            <ComboBoxItem Content="Heuristics Pane" Tag="heuristics"/>
                                            <ComboBoxItem Content="Filesystem Pane" Tag="filesystem"/>
                                            <ComboBoxItem Content="Process Relations Pane" Tag="process-relations"/>
                                            <ComboBoxItem Content="IPC Uplink Pane" Tag="ipc-uplink"/>
                                            <ComboBoxItem Content="Event Log Window" Tag="event-log"/>
                                            <ComboBoxItem Content="Switch View (API)" Tag="switch-view"/>
                                            <ComboBoxItem Content="ETW Inspector" Tag="inspector-etw"/>
                                            <ComboBoxItem Content="Heuristics Inspector" Tag="inspector-heuristics"/>
                                            <ComboBoxItem Content="Filesystem Inspector" Tag="inspector-filesystem"/>
                                            <ComboBoxItem Content="Process Relations Inspector" Tag="inspector-relations"/>
                                            <ComboBoxItem Content="Diagnostics Window" Tag="diagnostics"/>
                                        </ComboBox>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Switch View" Click="SwitchView_Click"/>
                                        <Separator Margin="8,0"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Events Float" Click="DockEventsToggle_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Perf Float" Click="DockPerfToggle_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="ETW Float" Click="DockEtwToggle_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Heur Float" Click="DockHeurToggle_Click"/>
                                        <Separator Margin="8,0"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Swap Main" Click="DockSwapMain_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Swap Intel" Click="DockSwapIntel_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Redock All" Click="ResetDock_Click"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Time Travel">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="2,0">
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,6">
                                        <TextBlock Text="Timeline"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                                        <Slider x:Name="TopTimeTravelSlider"
                                                Style="{StaticResource TopTimeTravelSliderStyle}"
                                                Minimum="0"
                                                Maximum="1"
                                                Value="0"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="False"
                                                Width="420"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                ValueChanged="TopTimeTravelSlider_ValueChanged"/>
                                        <Button Content="-10s"
                                                Style="{DynamicResource CommandBarButtonStyle}"
                                                Click="TopTimeTravelBack10_Click"/>
                                        <Button Content="-1s"
                                                Style="{DynamicResource CommandBarButtonStyle}"
                                                Click="TopTimeTravelBack1_Click"/>
                                        <Button Content="+1s"
                                                Style="{DynamicResource CommandBarButtonStyle}"
                                                Click="TopTimeTravelForward1_Click"/>
                                        <Button Content="+10s"
                                                Style="{DynamicResource CommandBarButtonStyle}"
                                                Click="TopTimeTravelForward10_Click"/>
                                        <TextBlock x:Name="TopTimeTravelRangeBlock"
                                                   Text="Range: --"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Session">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="2,0">
                                    <StackPanel Orientation="Horizontal" Margin="8,6,8,6">
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Open" Click="OpenSession_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Import" Click="ImportSession_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Save" Click="SaveSessionAs_Click"/>
                                        <Button Style="{DynamicResource CommandBarButtonStyle}" Content="Export" Click="ExportSession_Click"/>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="2,6,0,0">
                        <TextBox x:Name="PidBox" Visibility="Collapsed"/>

                        <Border Background="{Binding ElementName=ProcessStateBadge, Path=Background}"
                                BorderBrush="{Binding ElementName=ProcessStateBadge, Path=BorderBrush}"
                                BorderThickness="0"
                                Padding="7,2"
                                Margin="0,0,8,0"
                                CornerRadius="2">
                            <TextBlock Text="{Binding ElementName=ProcessStateBlock, Path=Text}"
                                       Foreground="{Binding ElementName=ProcessStateBlock, Path=Foreground}"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </Border>

                        <TextBlock x:Name="StatusBlock"
                                   Text="Status: Disconnected"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                        <TextBlock x:Name="RangeBlock"
                                   Text="Range:"
                                   VerticalAlignment="Center"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="220"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1,1,0,1"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource WinHeaderBrush}"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,0">
                        <TextBlock Text="GRAPH EXPLORER"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="GraphExplorer"
                             Background="{DynamicResource WinPanelBrush}"
                             Style="{DynamicResource ExplorerListStyle}"
                             ItemContainerStyle="{DynamicResource ExplorerItemStyle}"
                             SelectionMode="Single"
                             PreviewMouseLeftButtonUp="GraphExplorer_PreviewMouseLeftButtonUp">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        Height="96"
                                        Background="{DynamicResource WinPanelBrush}">
                                    <Grid>
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Opacity" Value="0.35"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <Rectangle Fill="{DynamicResource ExplorerPreviewBackgroundBrush}"/>

                                        <local:SparklinePreviewControl Margin="6"
                                                                       Values="{Binding PreviewValues}"
                                                                       Stroke="{Binding AccentBrush}"/>

                                        <Border x:Name="NoDataBadge"
                                                Margin="6"
                                                Background="{DynamicResource NoDataOverlayBrush}"
                                                Visibility="Collapsed">
                                            <TextBlock Text="NO DATA"
                                                       FontWeight="Bold"
                                                       FontSize="18"
                                                       Opacity="0.72"
                                                       Foreground="{DynamicResource WinTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <Border HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="8,8,0,0"
                                                Background="{DynamicResource ExplorerOverlayBrush}"
                                                Padding="6,2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"/>
                                        </Border>

                                        <Border x:Name="DetailsBadge"
                                                Margin="6,0,6,6"
                                                VerticalAlignment="Bottom"
                                                Background="{DynamicResource ExplorerOverlayBrush}"
                                                Padding="6,3"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DetailPrimary}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding DetailSecondary}"
                                                           FontSize="10"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource WinMutedTextBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding HasData}" Value="False">
                                        <Setter TargetName="NoDataBadge" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ShowDetails}" Value="True">
                                        <Setter TargetName="DetailsBadge" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                                        <Setter TargetName="DetailsBadge" Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="2"
                          Background="{DynamicResource WinSubtleBorderBrush}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="IpcUplinkColumn" Width="0"/>
                    <ColumnDefinition x:Name="IpcUplinkSplitterColumn" Width="0"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="IntelligenceSplitterColumn" Width="2"/>
                    <ColumnDefinition x:Name="IntelligenceColumn" Width="560"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        x:Name="IpcUplinkDockBorder"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1,1,0,1"
                        MinWidth="360"
                        Margin="0,0,0,0"
                        Background="{DynamicResource WinPanelBrush}"
                        Visibility="Collapsed">
                    <local:IpcUplinkPane x:Name="IpcUplinkPaneHost"/>
                </Border>

                <GridSplitter Grid.Column="1"
                              x:Name="IpcUplinkSplitter"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Visibility="Collapsed"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource WinHeaderBrush}"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,1,1,0"
                            Padding="4,0">
                        <DockPanel LastChildFill="True">
                            <Button Content="New Tab"
                                    DockPanel.Dock="Right"
                                    Margin="6,2,0,2"
                                    Padding="10,2"
                                    MinWidth="72"
                                    Click="NewProcessTab_Click"/>

                            <TabControl x:Name="ProcessTabs"
                                        Style="{DynamicResource ProcessTabStripStyle}"
                                        BorderThickness="0"
                                        Background="{DynamicResource WinHeaderBrush}"
                                        SelectionChanged="ProcessTabs_SelectionChanged">
                                <TabControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True">
                                            <TextBlock Text="{Binding Title}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,6,0"
                                                       MaxWidth="220"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Button Content="x"
                                                    DockPanel.Dock="Right"
                                                    Width="16"
                                                    Height="16"
                                                    Padding="0"
                                                    Margin="0"
                                                    MinWidth="16"
                                                    MinHeight="16"
                                                    Tag="{Binding}"
                                                    Click="CloseProcessTab_Click"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </TabControl.ItemTemplate>
                            </TabControl>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Row="1" x:Name="DockGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4*"/>
                            <RowDefinition Height="2"/>
                            <RowDefinition Height="5*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" x:Name="EventsPaneRow">
                            <Border x:Name="EventsDockBorder"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1,1,1,0"
                                    Background="{DynamicResource WinPanelBrush}">
                                <local:EventsPane x:Name="EventsPaneHost"/>
                            </Border>

                            <Border x:Name="CollapsedEventsBar"
                                    Visibility="Collapsed"
                                    Height="28"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource EventsHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MouseLeftButtonUp="CollapsedEventsBar_MouseLeftButtonUp">
                                <Grid>
                                    <TextBlock Text="Events (collapsed)"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Click to open"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource WinMutedTextBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Row="1"
                                      x:Name="DockSplitter"
                                      Height="2"
                                      Background="{DynamicResource WinSubtleBorderBrush}"
                                      HorizontalAlignment="Stretch"
                                      ShowsPreview="True"/>

                        <Grid Grid.Row="2" x:Name="PerformancePaneRow">
                            <Border x:Name="PerformanceDockBorder"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1,0,1,1"
                                    Background="{DynamicResource WinPanelBrush}">
                                <local:PerformancePane x:Name="PerformancePaneHost"/>
                            </Border>

                            <Border x:Name="CollapsedPerformanceBar"
                                    Visibility="Collapsed"
                                    Height="28"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource PerformanceHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MouseLeftButtonUp="CollapsedPerformanceBar_MouseLeftButtonUp">
                                <Grid>
                                    <TextBlock Text="Performance (collapsed)"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Click to open"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource WinMutedTextBrush}"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border x:Name="DockPreviewTop"
                                Grid.Row="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                Margin="6"
                                BorderThickness="2"
                                BorderBrush="#CC8FC7FF"
                                Background="#223A6EA5"/>

                        <Border x:Name="DockPreviewBottom"
                                Grid.Row="2"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                Margin="6"
                                BorderThickness="2"
                                BorderBrush="#CC8FC7FF"
                                Background="#223A6EA5"/>
                    </Grid>

                    <Border Grid.Row="1"
                            x:Name="ApiViewBorder"
                            Visibility="Collapsed"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource WinPanelBrush}">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{DynamicResource WinHeaderBrush}"
                                    Padding="8,4"
                                    Margin="0,0,0,8">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="BlackbirdHook/Sensor API View"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ApiViewSummaryBlock"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Text="No API hook data yet"/>
                                    <TextBlock x:Name="ApiViewSubSummaryBlock"
                                               DockPanel.Dock="Right"
                                               Foreground="{DynamicResource WinMutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Text="live call graph + memory telemetry"/>
                                </DockPanel>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.35*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.45*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource WinPanelBrush}">
                                    <DataGrid x:Name="ApiViewDataGrid"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserReorderColumns="False"
                                              CanUserResizeRows="False"
                                              ColumnHeaderHeight="24"
                                              RowHeight="28"
                                              BorderThickness="0"
                                              SelectionChanged="ApiViewDataGrid_SelectionChanged">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="API" Width="1.25*" Binding="{Binding ApiName}"/>
                                            <DataGridTextColumn Header="Path" Width="1.08*" Binding="{Binding PathLabel}"/>
                                            <DataGridTextColumn Header="Thread" Width="86" Binding="{Binding ThreadLabel}"/>
                                            <DataGridTextColumn Header="Hits" Width="68" Binding="{Binding Hits}"/>
                                            <DataGridTemplateColumn Header="Flame" Width="1.1*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="2,0">
                                                            <Border Height="12"
                                                                    CornerRadius="2"
                                                                    Background="#21262D"
                                                                    BorderBrush="#2D333B"
                                                                    BorderThickness="1">
                                                                <ProgressBar Minimum="0"
                                                                             Maximum="100"
                                                                             Value="{Binding HeatPercent}"
                                                                             Height="12"
                                                                             VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Heat" Width="70" Binding="{Binding HeatLabel}"/>
                                            <DataGridTextColumn Header="What It Did" Width="2.1*">
                                                <DataGridTextColumn.Binding>
                                                    <Binding Path="DecodedAction"/>
                                                </DataGridTextColumn.Binding>
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="TextWrapping" Value="NoWrap"/>
                                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                        <Setter Property="ToolTip" Value="{Binding DecodedAction}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Last Seen" Width="110" Binding="{Binding LastSeen}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <Border Grid.Column="2"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource WinPanelBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="1.35*"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0"
                                                Background="{DynamicResource WinHeaderBrush}"
                                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,4">
                                            <TextBlock Text="Selected Call (Decoded)" FontWeight="SemiBold"/>
                                        </Border>

                                        <StackPanel Grid.Row="1" Margin="8,6,8,4">
                                            <TextBlock x:Name="ApiViewSelectedTitleBlock"
                                                       FontWeight="SemiBold"
                                                       Text="No selection"/>
                                            <TextBlock x:Name="ApiViewSelectedMetaBlock"
                                                       Margin="0,3,0,0"
                                                       Foreground="{DynamicResource WinMutedTextBrush}"
                                                       Text="Select a row to inspect decoded details"/>
                                        </StackPanel>

                                        <TextBox Grid.Row="2"
                                                 Margin="8,0,8,0"
                                                 x:Name="ApiViewSelectedDetailsTextBox"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                 BorderThickness="1"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Disabled"
                                                 AcceptsReturn="True"
                                                 Background="{DynamicResource WinPanelBrush}"/>

                                        <Border Grid.Row="4"
                                                Margin="0,0,0,0"
                                                Background="{DynamicResource WinHeaderBrush}"
                                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                                BorderThickness="0,1,0,1"
                                                Padding="8,4">
                                            <TextBlock Text="DOT Graph" FontWeight="SemiBold"/>
                                        </Border>

                                        <TextBox Grid.Row="5"
                                                 x:Name="ApiViewDotGraphTextBox"
                                                 FontFamily="Consolas"
                                                 FontSize="12"
                                                 BorderThickness="0"
                                                 IsReadOnly="True"
                                                 TextWrapping="NoWrap"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 AcceptsReturn="True"
                                                 Background="{DynamicResource WinPanelBrush}"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="3"
                              x:Name="IntelligenceSplitter"
                              Width="2"
                              Background="{DynamicResource WinSubtleBorderBrush}"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"/>

                <Grid Grid.Column="4" x:Name="IntelligenceDock">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            x:Name="EtwDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,1,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:EtwPane x:Name="EtwPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="1"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="2"
                            x:Name="HeuristicsDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:HeuristicsPane x:Name="HeuristicsPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="3"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="4"
                            x:Name="FilesystemDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,0"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:FilesystemPane x:Name="FilesystemPaneHost"/>
                    </Border>

                    <GridSplitter Grid.Row="5"
                                  Height="2"
                                  Background="{DynamicResource WinSubtleBorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"/>

                    <Border Grid.Row="6"
                            x:Name="ProcessRelationsDockBorder"
                            BorderBrush="{DynamicResource WinBorderBrush}"
                            BorderThickness="1,0,1,1"
                            Background="{DynamicResource WinPanelBrush}">
                        <local:ProcessRelationsPane x:Name="ProcessRelationsPaneHost"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

    </Grid>
</Window>
