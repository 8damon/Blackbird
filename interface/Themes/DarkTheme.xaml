<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="WinBgColor">#FF0C0C0C</Color>
    <Color x:Key="WinPanelColor">#FF141414</Color>
    <Color x:Key="WinHeaderColor">#FF1B1B1B</Color>
    <Color x:Key="WinBorderColor">#FF2B2B2B</Color>
    <Color x:Key="WinSubtleBorderColor">#FF242424</Color>
    <Color x:Key="WinTextColor">#FFD8D8D8</Color>
    <Color x:Key="WinMutedTextColor">#FF9E9E9E</Color>
    <Color x:Key="WinAccentColor">#FF7A7A7A</Color>
    <Color x:Key="InputHoverBorderColor">#FF404040</Color>
    <Color x:Key="CommandBarBackgroundColor">#FF171717</Color>
    <Color x:Key="CommandBarPanelColor">#FF111111</Color>
    <Color x:Key="CommandBarButtonColor">#FF101010</Color>
    <Color x:Key="StatusConnectedColor">#FF59BA59</Color>
    <Color x:Key="StatusFailedColor">#FFE0A144</Color>
    <Color x:Key="StatusBarNeutralColor">#FF101010</Color>
    <Color x:Key="StatusBarFailedColor">#FF2D1F10</Color>

    <Color x:Key="EventsHeaderColor">#FF0F355B</Color>
    <Color x:Key="EventsHeaderButtonColor">#FF1C4E82</Color>
    <Color x:Key="PerformanceHeaderColor">#FF2A5A2A</Color>
    <Color x:Key="PerformanceHeaderAccentColor">#FF4D8D4D</Color>
    <Color x:Key="EtwHeaderColor">#FF5A4218</Color>
    <Color x:Key="EtwFeedHeaderColor">#FF7A5721</Color>
    <Color x:Key="EtwTiHeaderColor">#FF4A306F</Color>
    <Color x:Key="HeuristicsHeaderColor">#FF5F1E1E</Color>
    <Color x:Key="MessageBoxBgColor">#FF080808</Color>
    <Color x:Key="MessageBoxTextColor">#FFE6E6E6</Color>
    <Color x:Key="MessageBoxMutedTextColor">#FFB0B0B0</Color>
    <Color x:Key="ProcessRowDefaultForegroundColor">#FFD8D8D8</Color>
    <Color x:Key="ProcessRowUnsignedBackgroundColor">#33501F1F</Color>
    <Color x:Key="ProcessRowUnsignedBorderColor">#AAE36B6B</Color>
    <Color x:Key="ProcessRowUnsignedForegroundColor">#FFF4D7D7</Color>
    <Color x:Key="ProcessRowAppContainerBackgroundColor">#333A2A58</Color>
    <Color x:Key="ProcessRowAppContainerBorderColor">#99B07AE8</Color>
    <Color x:Key="ProcessRowAppContainerForegroundColor">#FFF5F5F5</Color>
    <Color x:Key="ProcessRowLowIntegrityBackgroundColor">#2D4C411D</Color>
    <Color x:Key="ProcessRowLowIntegrityBorderColor">#88D1B05C</Color>
    <Color x:Key="ProcessRowElevatedBackgroundColor">#242D3C52</Color>
    <Color x:Key="ProcessRowElevatedBorderColor">#708AA8C7</Color>
    <Color x:Key="ProcessRowSystemBackgroundColor">#22232323</Color>
    <Color x:Key="ProcessRowSystemBorderColor">#555A5A5A</Color>
    <Color x:Key="ProcessRowSystemForegroundColor">#FFB8B8B8</Color>
    <Color x:Key="LaneRowEnabledColor">#2A285B2E</Color>
    <Color x:Key="LaneRowDisabledColor">#2A5B2828</Color>

    <SolidColorBrush x:Key="WinBgBrush" Color="{StaticResource WinBgColor}"/>
    <SolidColorBrush x:Key="WinPanelBrush" Color="{StaticResource WinPanelColor}"/>
    <SolidColorBrush x:Key="WinHeaderBrush" Color="{StaticResource WinHeaderColor}"/>
    <SolidColorBrush x:Key="WinBorderBrush" Color="{StaticResource WinBorderColor}"/>
    <SolidColorBrush x:Key="WinSubtleBorderBrush" Color="{StaticResource WinSubtleBorderColor}"/>
    <SolidColorBrush x:Key="WinTextBrush" Color="{StaticResource WinTextColor}"/>
    <SolidColorBrush x:Key="WinMutedTextBrush" Color="{StaticResource WinMutedTextColor}"/>
    <SolidColorBrush x:Key="WinAccentBrush" Color="{StaticResource WinAccentColor}"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="{StaticResource InputHoverBorderColor}"/>
    <SolidColorBrush x:Key="CommandBarBackgroundBrush" Color="{StaticResource CommandBarBackgroundColor}"/>
    <SolidColorBrush x:Key="CommandBarPanelBrush" Color="{StaticResource CommandBarPanelColor}"/>
    <SolidColorBrush x:Key="CommandBarButtonBrush" Color="{StaticResource CommandBarButtonColor}"/>
    <SolidColorBrush x:Key="StatusConnectedBrush" Color="{StaticResource StatusConnectedColor}"/>
    <SolidColorBrush x:Key="StatusFailedBrush" Color="{StaticResource StatusFailedColor}"/>
    <SolidColorBrush x:Key="StatusBarNeutralBrush" Color="{StaticResource StatusBarNeutralColor}"/>
    <SolidColorBrush x:Key="StatusBarFailedBrush" Color="{StaticResource StatusBarFailedColor}"/>

    <SolidColorBrush x:Key="EventsHeaderBrush" Color="{StaticResource EventsHeaderColor}"/>
    <SolidColorBrush x:Key="EventsHeaderButtonBrush" Color="{StaticResource EventsHeaderButtonColor}"/>
    <SolidColorBrush x:Key="PerformanceHeaderBrush" Color="{StaticResource PerformanceHeaderColor}"/>
    <SolidColorBrush x:Key="PerformanceHeaderAccentBrush" Color="{StaticResource PerformanceHeaderAccentColor}"/>
    <SolidColorBrush x:Key="EtwHeaderBrush" Color="{StaticResource EtwHeaderColor}"/>
    <SolidColorBrush x:Key="EtwFeedHeaderBrush" Color="{StaticResource EtwFeedHeaderColor}"/>
    <SolidColorBrush x:Key="EtwTiHeaderBrush" Color="{StaticResource EtwTiHeaderColor}"/>
    <SolidColorBrush x:Key="HeuristicsHeaderBrush" Color="{StaticResource HeuristicsHeaderColor}"/>
    <SolidColorBrush x:Key="MessageBoxBgBrush" Color="{StaticResource MessageBoxBgColor}"/>
    <SolidColorBrush x:Key="MessageBoxTextBrush" Color="{StaticResource MessageBoxTextColor}"/>
    <SolidColorBrush x:Key="MessageBoxMutedTextBrush" Color="{StaticResource MessageBoxMutedTextColor}"/>
    <SolidColorBrush x:Key="ProcessRowDefaultForegroundBrush" Color="{StaticResource ProcessRowDefaultForegroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowUnsignedBackgroundBrush" Color="{StaticResource ProcessRowUnsignedBackgroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowUnsignedBorderBrush" Color="{StaticResource ProcessRowUnsignedBorderColor}"/>
    <SolidColorBrush x:Key="ProcessRowUnsignedForegroundBrush" Color="{StaticResource ProcessRowUnsignedForegroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowAppContainerBackgroundBrush" Color="{StaticResource ProcessRowAppContainerBackgroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowAppContainerBorderBrush" Color="{StaticResource ProcessRowAppContainerBorderColor}"/>
    <SolidColorBrush x:Key="ProcessRowAppContainerForegroundBrush" Color="{StaticResource ProcessRowAppContainerForegroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowLowIntegrityBackgroundBrush" Color="{StaticResource ProcessRowLowIntegrityBackgroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowLowIntegrityBorderBrush" Color="{StaticResource ProcessRowLowIntegrityBorderColor}"/>
    <SolidColorBrush x:Key="ProcessRowElevatedBackgroundBrush" Color="{StaticResource ProcessRowElevatedBackgroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowElevatedBorderBrush" Color="{StaticResource ProcessRowElevatedBorderColor}"/>
    <SolidColorBrush x:Key="ProcessRowSystemBackgroundBrush" Color="{StaticResource ProcessRowSystemBackgroundColor}"/>
    <SolidColorBrush x:Key="ProcessRowSystemBorderBrush" Color="{StaticResource ProcessRowSystemBorderColor}"/>
    <SolidColorBrush x:Key="ProcessRowSystemForegroundBrush" Color="{StaticResource ProcessRowSystemForegroundColor}"/>
    <SolidColorBrush x:Key="LaneRowEnabledBrush" Color="{StaticResource LaneRowEnabledColor}"/>
    <SolidColorBrush x:Key="LaneRowDisabledBrush" Color="{StaticResource LaneRowDisabledColor}"/>

    <SolidColorBrush x:Key="ExplorerPreviewBackgroundBrush" Color="#FF111111"/>
    <SolidColorBrush x:Key="ExplorerOverlayBrush" Color="#CC181818"/>
    <SolidColorBrush x:Key="NoDataOverlayBrush" Color="#44000000"/>

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF121212"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFD8D8D8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#333A3A3A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF1C1C1C"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFD8D8D8"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF141414"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFD8D8D8"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WinBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource WinPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource WinMutedTextBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource WinHeaderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="MinWidth" Value="70"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF2A2A2A"/>
                            <Setter Property="BorderBrush" Value="#FF3E3E3E"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#FF181818"/>
                            <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource WinHeaderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="MinWidth" Value="70"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FF2A2A2A"/>
                            <Setter Property="BorderBrush" Value="#FF3E3E3E"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#FF181818"/>
                            <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Background" Value="#FF181818"/>
                            <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Background" Value="#FF181818"/>
                <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PaneIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinWidth" Value="24"/>
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="4,3,0,3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#00000000"/>
        <Setter Property="Background" Value="#00000000"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#33333333"/>
                            <Setter Property="BorderBrush" Value="#66505050"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#55404040"/>
                            <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#FF121212"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="CaretBrush" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="SelectionBrush" Value="#66505050"/>
        <Setter Property="SelectionOpacity" Value="0.9"/>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="#FF121212"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF121212"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFD8D8D8"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#333A3A3A"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF0F0F0"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF1C1C1C"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFD8D8D8"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF141414"/>
            <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFD8D8D8"/>
        </Style.Resources>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="#FF121212"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="6,2"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#FF2A2A2A"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#334C8FD2"/>
                <Setter Property="Foreground" Value="#FFF1F5FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource WinPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#44353535"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#332C2C2C"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBox" x:Key="ExplorerListStyle" BasedOn="{StaticResource {x:Type ListBox}}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <Style TargetType="ListBoxItem" x:Key="ExplorerItemStyle" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style TargetType="DataGrid" x:Key="AppDataGridStyle">
        <Setter Property="Background" Value="{StaticResource WinPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowBackground" Value="#FF171717"/>
        <Setter Property="AlternatingRowBackground" Value="#FF171717"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
    </Style>

    <Style TargetType="DataGrid" BasedOn="{StaticResource AppDataGridStyle}"/>

    <Style TargetType="DataGridColumnHeader" x:Key="AppDataGridColumnHeaderStyle">
        <Setter Property="Background" Value="#FF212121"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,5"/>
    </Style>

    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource AppDataGridColumnHeaderStyle}"/>

    <Style TargetType="DataGridRow" x:Key="AppDataGridRowStyle">
        <Setter Property="Background" Value="#FF171717"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF202020"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#334C8FD2"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow" BasedOn="{StaticResource AppDataGridRowStyle}"/>

    <Style TargetType="DataGridCell" x:Key="AppDataGridCellStyle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="6,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1E4C8FD2"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
                <Setter Property="Background" Value="#264C8FD2"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#334C8FD2"/>
                <Setter Property="Foreground" Value="#FFF1F5FF"/>
                <Setter Property="BorderBrush" Value="{StaticResource WinSubtleBorderBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell" BasedOn="{StaticResource AppDataGridCellStyle}"/>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="{StaticResource WinHeaderBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel"
                                      IsItemsHost="True"
                                      Background="{TemplateBinding Background}"
                                      Margin="2,0,2,0"/>
                        </Border>

                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="#FF141414"/>
        <Setter Property="Foreground" Value="{StaticResource WinMutedTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,1,1,0"
                            Margin="0,0,4,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#FF1C1C1C"/>
                            <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#FF101010"/>
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FF3A3A3A"/>
                            <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Thumb">
        <Setter Property="Background" Value="#FF3A3A3A"/>
        <Setter Property="BorderBrush" Value="#FF4D4D4D"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF4A4A4A"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="Background" Value="#FF5A5A5A"/>
                <Setter Property="BorderBrush" Value="{StaticResource WinAccentBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="#FF111111"/>
        <Setter Property="Foreground" Value="{StaticResource WinMutedTextBrush}"/>
        <Setter Property="Width" Value="11"/>
        <Setter Property="Height" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}"
                          SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track"
                               Orientation="{TemplateBinding Orientation}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="11"/>
                <Setter Property="Width" Value="Auto"/>
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="11"/>
                <Setter Property="Height" Value="Auto"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource CommandBarBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="4,1"/>
    </Style>

    <Style TargetType="ToolBarTray">
        <Setter Property="Background" Value="{StaticResource CommandBarBackgroundBrush}"/>
    </Style>

    <Style TargetType="ToolBar">
        <Setter Property="Background" Value="{StaticResource CommandBarBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="2,2,2,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ToolBarPanel IsItemsHost="True"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource WinPanelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource WinTextBrush}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="8,4"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#332C2C2C"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="Margin" Value="4,2"/>
    </Style>

    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WinSubtleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ShowsPreview" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF383838"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
