<Window x:Class="SleepwalkerInterface.ThreadStackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thread Stack"
        Height="920"
        Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WinBgBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderBlock" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   x:Name="ThreadMetaBlock"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource WinMutedTextBrush}"
                   TextWrapping="Wrap"/>

        <DataGrid Grid.Row="2"
                  x:Name="StackGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  ColumnHeaderHeight="24"
                  RowHeight="22"
                  CanUserResizeRows="False"
                  GridLinesVisibility="None">
            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="60"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="160"/>
                <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="190"/>
                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,8,0,0" LastChildFill="False">
            <TextBlock x:Name="NoteBlock" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{DynamicResource WinMutedTextBrush}"/>
            <Button DockPanel.Dock="Right" Content="Close" Padding="12,4" Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
