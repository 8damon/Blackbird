<Window x:Class="BlackbirdInterface.ChildProcessGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Child Process Graph"
        Height="860"
        Width="760"
        MinHeight="620"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">

    <Grid Margin="14,0,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SecondaryWindowTitleBarBorderStyle}"
                Margin="0,0,0,12"
                MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Child Process Graph"
                               Style="{StaticResource SecondaryWindowTitleTextStyle}"/>
                    <TextBlock x:Name="TargetBlock"
                               Style="{StaticResource SecondaryWindowSubtitleTextStyle}"
                               Text="PID 0"/>
                </StackPanel>
                <TextBlock x:Name="SummaryBlock"
                           DockPanel.Dock="Left"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource WinMutedTextBrush}"
                           Text="No monitored descendants or pivots yet"/>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Tag="Close"
                        Style="{StaticResource SecondaryWindowTitleGlyphButtonStyle}"
                        Click="Close_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource SecondaryWindowSurfaceBorderStyle}"
                Padding="0">
            <Grid>
                <TreeView x:Name="RelationsTree"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Margin="0,2,0,2">
                                <DockPanel LastChildFill="True">
                                    <Ellipse Width="8"
                                             Height="8"
                                             Margin="0,4,8,0"
                                             VerticalAlignment="Top"
                                             Fill="{Binding DotBrush}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding TitleBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding Meta}"
                                                   Margin="0,1,0,0"
                                                   Foreground="{DynamicResource WinMutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <Border x:Name="NoDataOverlay"
                        Background="{DynamicResource NoDataOverlayBrush}"
                        IsHitTestVisible="False"
                        Visibility="Collapsed">
                    <TextBlock Text="NO GRAPH DATA"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="{DynamicResource WinTextBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.72"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
