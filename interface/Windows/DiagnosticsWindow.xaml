<Window x:Class="BlackbirdInterface.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostics Cockpit"
        Height="900"
        Width="1600"
        MinHeight="760"
        MinWidth="1360"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">

    <Window.Resources>
        <DataTemplate x:Key="DiagnosticCardTemplate">
            <Border Margin="0,0,0,10"
                    Padding="12,11"
                    BorderThickness="1"
                    CornerRadius="12"
                    BorderBrush="{Binding BorderBrush}"
                    Background="{Binding Background}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Width="9"
                            Height="9"
                            Margin="0,4,10,0"
                            VerticalAlignment="Top"
                            CornerRadius="2"
                            Background="{Binding StatusDotBrush}"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding Key}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                        <TextBlock Text="{Binding Value}"
                                   Margin="0,5,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Foreground="{Binding Foreground}"/>
                        <TextBlock Text="{Binding StatusLabel}"
                                   Margin="0,6,0,0"
                                   FontSize="11"
                                   Foreground="{Binding Foreground}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <Style x:Key="BoardColumnBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource WinBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#FF101010"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="BoardColumnHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WinHeaderBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinSubtleBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,0,14,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource WinHeaderBrush}"
                Padding="12,8"
                Margin="0,0,0,12"
                MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Diagnostics Cockpit"
                               FontSize="15"
                               FontWeight="SemiBold"/>
                    <Border Margin="12,0,0,0"
                            Padding="10,3"
                            CornerRadius="999"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource WinPanelBrush}">
                        <TextBlock x:Name="TargetBlock"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                    </Border>
                </StackPanel>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Width="24"
                        Height="22"
                        Margin="8,0,0,0"
                        VerticalAlignment="Top"
                        Click="Close_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource BoardColumnBorderStyle}"
                Padding="16,14"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="SUBSYSTEMS RUNNING"
                           FontSize="18"
                           FontWeight="Bold"/>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center">
                    <Border Margin="8,0,0,0"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#221D4C2F"
                            BorderBrush="#FF4DC274"
                            BorderThickness="1">
                        <TextBlock x:Name="GoodCountBlock"
                                   Text="0 running"
                                   Foreground="#FFBEF7CD"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#221F2730"
                            BorderBrush="#FF7E8791"
                            BorderThickness="1">
                        <TextBlock x:Name="DisabledCountBlock"
                                   Text="0 disabled"
                                   Foreground="#FFD2D8DE"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#225E4912"
                            BorderBrush="#FFE3B945"
                            BorderThickness="1">
                        <TextBlock x:Name="WarningCountBlock"
                                   Text="0 warning"
                                   Foreground="#FFF7E6A6"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <Border Margin="8,0,0,0"
                            Padding="10,5"
                            CornerRadius="999"
                            Background="#225E1E1E"
                            BorderBrush="#FFDF6363"
                            BorderThickness="1">
                        <TextBlock x:Name="BadCountBlock"
                                   Text="0 failed"
                                   Foreground="#FFFFC5C5"
                                   FontWeight="SemiBold"/>
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource BoardColumnBorderStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource BoardColumnHeaderStyle}">
                        <TextBlock Text="Subsystems" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12,12,12,2">
                        <ItemsControl x:Name="SubsystemItemsControl"
                                      ItemTemplate="{StaticResource DiagnosticCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource BoardColumnBorderStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource BoardColumnHeaderStyle}">
                        <TextBlock Text="Integrity" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12,12,12,2">
                        <ItemsControl x:Name="IntegrityItemsControl"
                                      ItemTemplate="{StaticResource DiagnosticCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource BoardColumnBorderStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource BoardColumnHeaderStyle}">
                        <TextBlock Text="Transport And Capture" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12,12,12,2">
                        <ItemsControl x:Name="DataItemsControl"
                                      ItemTemplate="{StaticResource DiagnosticCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="6" Style="{StaticResource BoardColumnBorderStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top" Style="{StaticResource BoardColumnHeaderStyle}">
                        <TextBlock Text="Other Telemetry" FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="12,12,12,2">
                        <ItemsControl x:Name="OtherItemsControl"
                                      ItemTemplate="{StaticResource DiagnosticCardTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="8" Style="{StaticResource BoardColumnBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource BoardColumnHeaderStyle}">
                            <DockPanel>
                                <TextBlock Text="Output Feed" FontSize="13" FontWeight="SemiBold"/>
                                <Button DockPanel.Dock="Right"
                                        Content="Clear"
                                        Padding="10,2"
                                        Height="24"
                                        Click="Clear_Click"/>
                            </DockPanel>
                        </Border>
                        <TextBox Grid.Row="1"
                                 x:Name="OutputBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code, Consolas"
                                 FontSize="12"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="12"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource BoardColumnHeaderStyle}">
                            <DockPanel>
                                <TextBlock Text="Controller Log" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ControllerLogPathBlock"
                                           Margin="10,0,0,0"
                                           Foreground="{DynamicResource WinMutedTextBrush}"
                                           FontSize="10"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>
                        <TextBox Grid.Row="1"
                                 x:Name="ControllerLogBox"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code, Consolas"
                                 FontSize="11"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="12"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
