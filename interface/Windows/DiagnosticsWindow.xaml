<Window x:Class="BlackbirdInterface.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diagnostics Output"
        Height="720"
        Width="1080"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">

    <Grid Margin="10,0,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="130"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource WinHeaderBrush}"
                    Padding="10,6"
                    Margin="0,0,0,8"
                    MouseLeftButtonDown="Root_MouseLeftButtonDown">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="Diagnostics Cockpit"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Border Margin="10,0,0,0"
                                Padding="8,2"
                                BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource WinPanelBrush}">
                            <TextBlock x:Name="TargetBlock"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource WinMutedTextBrush}"/>
                        </Border>
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Content="✕"
                            Width="24"
                            Height="22"
                            Margin="8,0,0,0"
                            VerticalAlignment="Top"
                            Click="Close_Click"/>
                </DockPanel>
            </Border>

            <UniformGrid Grid.Row="1"
                         Columns="3"
                         Margin="0,0,0,8">
                <Border Margin="0,0,6,0"
                        Padding="10,8"
                        BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource WinPanelBrush}">
                    <StackPanel>
                        <TextBlock Text="STATE LINES"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                        <TextBlock x:Name="StateLinesBlock"
                                   Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="-"/>
                    </StackPanel>
                </Border>
                <Border Margin="3,0"
                        Padding="10,8"
                        BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource WinPanelBrush}">
                    <StackPanel>
                        <TextBlock Text="OUTPUT LINES"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                        <TextBlock x:Name="OutputLinesBlock"
                                   Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="-"/>
                    </StackPanel>
                </Border>
                <Border Margin="6,0,0,0"
                        Padding="10,8"
                        BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                        BorderThickness="1"
                        Background="{DynamicResource WinPanelBrush}">
                    <StackPanel>
                        <TextBlock Text="LAST REFRESH"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WinMutedTextBrush}"/>
                        <TextBlock x:Name="RefreshStampBlock"
                                   Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Text="--:--:--"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Padding="6"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Live State Snapshot"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <TextBox Grid.Row="1"
                             x:Name="StateBox"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="11"/>
                </Grid>
            </Border>

            <TextBox Grid.Row="3"
                     x:Name="OutputBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12"/>

            <Grid Grid.Row="4" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Refresh State"
                            Padding="12,4"
                            Height="26"
                            Margin="0,0,8,0"
                            Click="RefreshState_Click"/>
                    <Button Content="Clear"
                            Padding="12,4"
                            Height="26"
                            Click="Clear_Click"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Close"
                        Padding="12,4"
                        Height="26"
                        HorizontalAlignment="Right"
                        Click="Close_Click"/>
            </Grid>
    </Grid>
</Window>
