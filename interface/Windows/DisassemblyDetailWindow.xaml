<Window x:Class="SleepwalkerInterface.DisassemblyDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Disassembly"
        Height="760"
        Width="1160"
        MinHeight="540"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WinPanelBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WinPanelBrush}"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="1"
                Padding="10,8">
            <StackPanel>
                <TextBlock x:Name="HeaderBlock"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="Disassembly"/>
                <TextBlock x:Name="SubHeaderBlock"
                           Margin="0,2,0,0"
                           Foreground="{DynamicResource WinMutedTextBrush}"
                           Text="No selection"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.75*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Addresses"
                           FontWeight="SemiBold"/>
                <DataGrid x:Name="AddressesGrid"
                          Margin="0,4,0,10"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeRows="False"
                          RowHeight="22"
                          ColumnHeaderHeight="22"
                          MinHeight="180"
                          Background="{DynamicResource WinPanelBrush}"
                          RowBackground="{DynamicResource WinPanelBrush}"
                          AlternatingRowBackground="{DynamicResource WinPanelBrush}"
                          BorderBrush="{DynamicResource WinBorderBrush}"
                          HorizontalGridLinesBrush="{DynamicResource WinSubtleBorderBrush}"
                          VerticalGridLinesBrush="{DynamicResource WinSubtleBorderBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Field" Width="150" Binding="{Binding Key}"/>
                        <DataGridTextColumn Header="Value" Width="*" Binding="{Binding Value}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Stub Bytes"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="StubHexBox"
                         Margin="0,4,0,0"
                         MinHeight="110"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="{DynamicResource WinHeaderBrush}"
                         Foreground="{DynamicResource WinTextBrush}"
                         BorderBrush="{DynamicResource WinBorderBrush}"/>
            </StackPanel>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource WinHeaderBrush}">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Disassembly"
                               FontWeight="SemiBold"/>
                    <RichTextBox x:Name="DisasmBox"
                                 Grid.Row="2"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource WinTextBrush}"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
