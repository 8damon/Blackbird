<Window x:Class="SleepwalkerInterface.EventRecordInspectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Event Inspector"
        Height="780"
        Width="1420"
        MinHeight="560"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">
    <Window.Resources>
        <Style x:Key="TitleBarGlyphButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WinHeaderBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource WinBorderBrush}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource WinBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource WinPanelBrush}"
                BorderBrush="{DynamicResource WinBorderBrush}"
                BorderThickness="1"
                Padding="10,8"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="HeaderBlock"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Text="Event Inspector"/>
                    <TextBlock x:Name="SubHeaderBlock"
                               Margin="0,2,0,0"
                               Foreground="{DynamicResource WinMutedTextBrush}"
                               Text="Single event record"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource TitleBarGlyphButtonStyle}"
                            Content="&#xE921;"
                            Click="WindowMinimize_Click"/>
                    <Button Style="{StaticResource TitleBarGlyphButtonStyle}"
                            Content="&#xE922;"
                            Margin="4,0,0,0"
                            Click="WindowMaximize_Click"/>
                    <Button Style="{StaticResource TitleBarGlyphButtonStyle}"
                            Content="&#xE8BB;"
                            Margin="4,0,0,0"
                            Click="WindowClose_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.95*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource WinPanelBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="Flow Graph" FontWeight="SemiBold"/>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{DynamicResource WinHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MinHeight="64"
                                    Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="Actor" FontWeight="SemiBold" Foreground="{DynamicResource WinMutedTextBrush}"/>
                                    <TextBlock x:Name="ActorNodeBlock" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       Text="→"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource WinAccentBrush}"/>

                            <Border Grid.Column="2"
                                    Background="{DynamicResource WinHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MinHeight="64"
                                    Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="Event / Detection" FontWeight="SemiBold" Foreground="{DynamicResource WinMutedTextBrush}"/>
                                    <TextBlock x:Name="EventNodeBlock" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Grid.Column="3"
                                       Margin="8,0"
                                       VerticalAlignment="Center"
                                       Text="→"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource WinAccentBrush}"/>

                            <Border Grid.Column="4"
                                    Background="{DynamicResource WinHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    MinHeight="64"
                                    Padding="8,6">
                                <StackPanel>
                                    <TextBlock Text="Target" FontWeight="SemiBold" Foreground="{DynamicResource WinMutedTextBrush}"/>
                                    <TextBlock x:Name="TargetNodeBlock" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Text="Source"
                                       Foreground="{DynamicResource WinMutedTextBrush}"/>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource WinHeaderBrush}"
                                    BorderBrush="{DynamicResource WinBorderBrush}"
                                    BorderThickness="1"
                                    Padding="6,4">
                                <TextBlock x:Name="SourceNodeBlock" TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="{DynamicResource WinPanelBrush}"
                        BorderBrush="{DynamicResource WinBorderBrush}"
                        BorderThickness="1"
                        Padding="8">
                    <DataGrid x:Name="FieldsGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeight="22"
                              ColumnHeaderHeight="24"
                              Background="{DynamicResource WinPanelBrush}"
                              RowBackground="{DynamicResource WinPanelBrush}"
                              AlternatingRowBackground="{DynamicResource WinPanelBrush}"
                              BorderBrush="{DynamicResource WinBorderBrush}"
                              HorizontalGridLinesBrush="{DynamicResource WinSubtleBorderBrush}"
                              VerticalGridLinesBrush="{DynamicResource WinSubtleBorderBrush}"
                              CanUserResizeRows="False"
                              CanUserReorderColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Field" Width="160" Binding="{Binding Key}"/>
                            <DataGridTemplateColumn Header="Value" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Column="2"
                    Background="{DynamicResource WinPanelBrush}"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Padding="10,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Decoded Summary" FontWeight="SemiBold"/>
                        <TextBox x:Name="DecodedBox"
                                 Margin="0,6,0,0"
                                 MinHeight="120"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="{DynamicResource WinHeaderBrush}"
                                 Foreground="{DynamicResource WinTextBrush}"
                                 BorderBrush="{DynamicResource WinBorderBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Raw Payload" FontWeight="SemiBold"/>
                        <TextBox x:Name="RawBox"
                                 Margin="0,6,0,0"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="{DynamicResource WinHeaderBrush}"
                                 Foreground="{DynamicResource WinTextBrush}"
                                 BorderBrush="{DynamicResource WinBorderBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
