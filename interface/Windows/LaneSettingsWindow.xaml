<Window x:Class="BlackbirdInterface.LaneSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lane Filter"
        Height="680"
        Width="980"
        MinHeight="560"
        MinWidth="820"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource WinBgBrush}">

    <Window.Resources>
        <Style x:Key="LaneComboToggleStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleRoot" Property="BorderBrush" Value="{DynamicResource InputHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleRoot" Property="BorderBrush" Value="{DynamicResource WinAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaneComboStyle"
               TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource WinBorderBrush}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <ToggleButton x:Name="DropDownToggle"
                                          Style="{DynamicResource LaneComboToggleStyle}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="1"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          ClickMode="Press">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="6,0,2,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Path Grid.Column="1"
                                          Width="8"
                                          Height="5"
                                          Stretch="Fill"
                                          Fill="{DynamicResource WinMutedTextBrush}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Data="M 0 0 L 8 0 L 4 5 Z"/>
                                </Grid>
                            </ToggleButton>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource WinPanelBrush}"
                                        BorderBrush="{DynamicResource WinBorderBrush}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer CanContentScroll="True"
                                                  SnapsToDevicePixels="True"
                                                  Background="{DynamicResource WinPanelBrush}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="{DynamicResource InputHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="DropDownToggle" Property="BorderBrush" Value="{DynamicResource WinAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaneComboItemStyle"
               TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,2"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WinHeaderBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LaneRuleRowStyle"
               TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource WinPanelBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
        </Style>

        <Style x:Key="LaneStateRowStyle"
               TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource WinTextBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="130"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,8"
                   LastChildFill="False"
                   MouseLeftButtonDown="Root_MouseLeftButtonDown">
            <TextBlock Text="Lane Filters"
                       FontWeight="SemiBold"
                       FontSize="14"
                       VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right"
                    Content="✕"
                    Width="22"
                    Height="20"
                    Margin="8,0,0,0"
                    VerticalAlignment="Top"
                    Click="Close_Click"/>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="RuleFieldBox" Grid.Column="0" SelectedIndex="0"
                      SelectionChanged="RuleFieldBox_SelectionChanged"
                      Style="{DynamicResource LaneComboStyle}"
                      ItemContainerStyle="{DynamicResource LaneComboItemStyle}">
                <ComboBoxItem Content="Lane"/>
                <ComboBoxItem Content="Group"/>
            </ComboBox>

            <ComboBox x:Name="RuleRelationBox" Grid.Column="1" SelectedIndex="0"
                      Style="{DynamicResource LaneComboStyle}"
                      ItemContainerStyle="{DynamicResource LaneComboItemStyle}">
                <ComboBoxItem Content="is"/>
                <ComboBoxItem Content="contains"/>
                <ComboBoxItem Content="begins with"/>
                <ComboBoxItem Content="ends with"/>
            </ComboBox>

            <ComboBox x:Name="RuleValueBox"
                      Grid.Column="2"
                      Margin="4,0"
                      Style="{DynamicResource LaneComboStyle}"
                      ItemContainerStyle="{DynamicResource LaneComboItemStyle}"
                      KeyDown="RuleValueBox_KeyDown"
                      IsTextSearchEnabled="True"/>

            <TextBlock Grid.Column="3"
                       Text="then"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource WinMutedTextBrush}"/>

            <ComboBox x:Name="RuleActionBox" Grid.Column="4" SelectedIndex="0"
                      Style="{DynamicResource LaneComboStyle}"
                      ItemContainerStyle="{DynamicResource LaneComboItemStyle}">
                <ComboBoxItem Content="Include"/>
                <ComboBoxItem Content="Exclude"/>
            </ComboBox>
        </Grid>

        <DataGrid Grid.Row="2"
                  x:Name="RulesGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  ColumnHeaderHeight="24"
                  RowHeight="22"
                  CanUserResizeRows="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  RowStyle="{DynamicResource LaneRuleRowStyle}">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="" Width="34">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Click="RuleEnabled_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="120"/>
                <DataGridTextColumn Header="Relation" Binding="{Binding Relation}" Width="130"/>
                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <DataGrid Grid.Row="4"
                  x:Name="LaneGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  ColumnHeaderHeight="24"
                  RowHeight="22"
                  CanUserResizeRows="False"
                  CanUserReorderColumns="True"
                  CanUserResizeColumns="True"
                  RowStyle="{DynamicResource LaneStateRowStyle}"
                  SelectionChanged="LaneGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Lane" Binding="{Binding Key}" Width="*"/>
                <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="180"/>
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="80"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Refresh lanes" Height="26" Margin="0,0,6,0" Click="Refresh_Click"/>
                <Button Content="Add rule" Height="26" Margin="0,0,6,0" Click="AddRule_Click"/>
                <Button Content="Remove rule" Height="26" Margin="0,0,6,0" Click="RemoveRule_Click"/>
                <Button Content="Up" Width="58" Height="26" Margin="0,0,6,0" Click="MoveRuleUp_Click"/>
                <Button Content="Down" Width="58" Height="26" Margin="0,0,6,0" Click="MoveRuleDown_Click"/>
                <Button Content="Clear rules" Height="26" Margin="0,0,6,0" Click="ClearRules_Click"/>
                <Button Content="Apply filters" Height="26" Click="ApplyFilters_Click"/>
            </StackPanel>

            <Button Grid.Column="1" Content="Close" Height="26" HorizontalAlignment="Right" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>
