<Window x:Class="SleepwalkerInterface.ThreadStackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thread Stack"
        Height="920"
        Width="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WinBgBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderBlock" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1"
                   x:Name="ThreadMetaBlock"
                   Margin="0,0,0,8"
                   Foreground="{DynamicResource WinMutedTextBrush}"
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource WinBorderBrush}"
                    BorderThickness="1"
                    Background="{DynamicResource WinPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource WinHeaderBrush}"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,0">
                        <TextBlock Text="Stack Memory"
                                   FontWeight="SemiBold"
                                   FontSize="11"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="6">
                        <Canvas x:Name="StackMapCanvas"
                                Background="{DynamicResource ExplorerPreviewBackgroundBrush}"
                                ClipToBounds="True"
                                SizeChanged="StackMapCanvas_SizeChanged"/>
                        <Border x:Name="StackMapNoDataOverlay"
                                Background="{DynamicResource NoDataOverlayBrush}"
                                IsHitTestVisible="False"
                                Visibility="Collapsed">
                            <TextBlock Text="NO STACK MAP"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource WinTextBrush}"
                                       Opacity="0.72"/>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="{DynamicResource WinHeaderBrush}"
                            BorderBrush="{DynamicResource WinSubtleBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="6,0">
                        <DockPanel LastChildFill="False">
                            <TextBlock x:Name="StackBaseBlock"
                                       DockPanel.Dock="Left"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Foreground="{DynamicResource WinMutedTextBrush}"
                                       Text="BASE: -"/>
                            <TextBlock x:Name="StackTopBlock"
                                       DockPanel.Dock="Right"
                                       FontFamily="Consolas"
                                       FontSize="10"
                                       Foreground="{DynamicResource WinMutedTextBrush}"
                                       Text="TOP: -"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <DataGrid Grid.Column="2"
                      x:Name="StackGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      ColumnHeaderHeight="24"
                      RowHeight="22"
                      CanUserResizeRows="False"
                      GridLinesVisibility="None">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="56"/>
                    <DataGridTextColumn Header="IP Address" Binding="{Binding Address}" Width="146"/>
                    <DataGridTextColumn Header="Frame Ptr" Binding="{Binding FramePointer}" Width="146"/>
                    <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="180"/>
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,8,0,0" LastChildFill="False">
            <TextBlock x:Name="NoteBlock" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{DynamicResource WinMutedTextBrush}"/>
            <Button DockPanel.Dock="Right" Content="Close" Padding="12,4" Click="Close_Click"/>
        </DockPanel>
    </Grid>
</Window>
